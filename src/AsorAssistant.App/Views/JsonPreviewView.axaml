<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AsorAssistant.App.ViewModels"
             x:Class="AsorAssistant.App.Views.JsonPreviewView"
             x:DataType="vm:JsonPreviewViewModel">

  <DockPanel Margin="20,12">
    <Border DockPanel.Dock="Top" Classes="card" Padding="16">
      <StackPanel Orientation="Horizontal" Spacing="12">
        <Button Classes="primary" Content="Refresh from Editor" Command="{Binding RefreshCommand}" />
        <Button Classes="add" Content="Copy to Clipboard" Command="{Binding CopyToClipboardCommand}"
                CommandParameter="{Binding $parent[TopLevel].Clipboard}" />
        <TextBlock Classes="status-success" Text="{Binding StatusMessage}" VerticalAlignment="Center"
                   IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
      </StackPanel>
    </Border>

    <Border Classes="card" Margin="0,0,0,0">
      <TextBox Classes="mono" Text="{Binding JsonText}" IsReadOnly="True"
               AcceptsReturn="True" TextWrapping="NoWrap" />
    </Border>
  </DockPanel>

</UserControl>
