<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AsorAssistant.App.ViewModels"
             x:Class="AsorAssistant.App.Views.JsonPreviewView"
             x:DataType="vm:JsonPreviewViewModel">

  <DockPanel Margin="24,20">
    <!-- Header -->
    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,16">
      <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
        <Button Classes="action" Content="Refresh" Command="{Binding RefreshCommand}" />
        <Button Classes="action" Content="Copy" Command="{Binding CopyToClipboardCommand}"
                CommandParameter="{Binding $parent[TopLevel].Clipboard}" />
        <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"
                   FontSize="12" Foreground="{StaticResource AppSuccessBrush}"
                   IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
      </StackPanel>
      <TextBlock Classes="page-title" Text="JSON Preview" VerticalAlignment="Center" />
    </DockPanel>

    <!-- JSON output -->
    <TextBox Classes="mono" Text="{Binding JsonText}" IsReadOnly="True"
             AcceptsReturn="True" TextWrapping="NoWrap" />
  </DockPanel>

</UserControl>
