<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AsorAssistant.App.ViewModels"
             x:Class="AsorAssistant.App.Views.DefinitionEditorView"
             x:DataType="vm:DefinitionEditorViewModel"
             x:Name="EditorRoot">

  <ScrollViewer Padding="20,12,20,40">
    <StackPanel Spacing="4" MaxWidth="820" HorizontalAlignment="Left">

      <!-- Identity -->
      <Border Classes="card">
        <StackPanel Spacing="12">
          <TextBlock Classes="section-header" Text="Identity" />
          <TextBlock Classes="section-desc" Text="Core agent identity fields required by the ASOR spec." />

          <StackPanel Spacing="4">
            <TextBlock Classes="field-label" Text="Name *" />
            <TextBox Text="{Binding Name}" PlaceholderText="Human-readable agent name" />
          </StackPanel>

          <StackPanel Spacing="4">
            <TextBlock Classes="field-label" Text="Description *" />
            <TextBox Text="{Binding Description}" PlaceholderText="What this agent does"
                     AcceptsReturn="True" TextWrapping="Wrap" Height="80" />
          </StackPanel>

          <Grid ColumnDefinitions="*,16,*">
            <StackPanel Spacing="4">
              <TextBlock Classes="field-label" Text="URL *" />
              <TextBox Text="{Binding Url}" PlaceholderText="https://agents.example.com/my-agent" />
            </StackPanel>
            <StackPanel Grid.Column="2" Spacing="4">
              <TextBlock Classes="field-label" Text="Version *" />
              <TextBox Text="{Binding Version}" PlaceholderText="1.0.0" />
            </StackPanel>
          </Grid>
        </StackPanel>
      </Border>

      <!-- Provider and Platform -->
      <Border Classes="card">
        <StackPanel Spacing="12">
          <TextBlock Classes="section-header" Text="Provider &amp; Platform" />

          <Grid ColumnDefinitions="*,16,*">
            <StackPanel Spacing="4">
              <TextBlock Classes="field-label" Text="Provider *" />
              <ComboBox ItemsSource="{Binding ProviderOptions}"
                        SelectedValue="{Binding SelectedProviderId}"
                        SelectedValueBinding="{Binding Id}"
                        DisplayMemberBinding="{Binding Name}"
                        PlaceholderText="Select provider..."
                        HorizontalAlignment="Stretch" />
              <TextBox Text="{Binding CustomProviderId}" PlaceholderText="Custom provider ID"
                       IsVisible="{Binding SelectedProviderId, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                       Margin="0,4,0,0" />
            </StackPanel>
            <StackPanel Grid.Column="2" Spacing="4">
              <TextBlock Classes="field-label" Text="Platform *" />
              <ComboBox ItemsSource="{Binding PlatformOptions}"
                        SelectedValue="{Binding SelectedPlatformId}"
                        SelectedValueBinding="{Binding Id}"
                        DisplayMemberBinding="{Binding Name}"
                        PlaceholderText="Select platform..."
                        HorizontalAlignment="Stretch" />
              <TextBox Text="{Binding CustomPlatformId}" PlaceholderText="Custom platform ID"
                       IsVisible="{Binding SelectedPlatformId, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                       Margin="0,4,0,0" />
            </StackPanel>
          </Grid>
        </StackPanel>
      </Border>

      <!-- Capabilities -->
      <Border Classes="card">
        <StackPanel Spacing="12">
          <TextBlock Classes="section-header" Text="Capabilities" />
          <TextBlock Classes="section-desc" Text="Feature flags indicating what the agent supports." />

          <StackPanel Orientation="Horizontal" Spacing="24">
            <CheckBox Content="Push Notifications" IsChecked="{Binding PushNotifications}" />
            <CheckBox Content="Streaming" IsChecked="{Binding Streaming}" />
            <CheckBox Content="State Transition History" IsChecked="{Binding StateTransitionHistory}" />
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Skills -->
      <Border Classes="card">
        <StackPanel Spacing="12">
          <DockPanel>
            <Button DockPanel.Dock="Right" Classes="add" Content="+ Add Skill"
                    Command="{Binding AddSkillCommand}" VerticalAlignment="Top" />
            <StackPanel>
              <TextBlock Classes="section-header" Text="Skills" />
              <TextBlock Classes="section-desc" Text="At least one skill is required. Skills define what the agent can do." />
            </StackPanel>
          </DockPanel>

          <ItemsControl ItemsSource="{Binding Skills}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:SkillViewModel">
                <Border Classes="card-nested">
                  <StackPanel Spacing="10">
                    <DockPanel>
                      <Button DockPanel.Dock="Right" Classes="remove" Content="Remove"
                              Command="{Binding #EditorRoot.((vm:DefinitionEditorViewModel)DataContext).RemoveSkillCommand}"
                              CommandParameter="{Binding}" />
                      <TextBlock Classes="card-title" Text="Skill" VerticalAlignment="Center" />
                    </DockPanel>

                    <Grid ColumnDefinitions="*,12,2*">
                      <StackPanel Spacing="4">
                        <TextBlock Classes="field-label" Text="ID *" />
                        <TextBox Text="{Binding Id}" PlaceholderText="unique-skill-id" />
                      </StackPanel>
                      <StackPanel Grid.Column="2" Spacing="4">
                        <TextBlock Classes="field-label" Text="Name *" />
                        <TextBox Text="{Binding Name}" PlaceholderText="Human-readable skill name" />
                      </StackPanel>
                    </Grid>

                    <StackPanel Spacing="4">
                      <TextBlock Classes="field-label" Text="Description *" />
                      <TextBox Text="{Binding Description}" PlaceholderText="What this skill does"
                               AcceptsReturn="True" TextWrapping="Wrap" Height="56" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                      <TextBlock Classes="field-label" Text="Tags (comma-separated)" />
                      <TextBox Text="{Binding TagsText}" PlaceholderText="tag1, tag2, tag3" />
                    </StackPanel>

                    <Grid ColumnDefinitions="*,12,*">
                      <StackPanel Spacing="4">
                        <TextBlock Classes="field-label" Text="Input Modes (comma-separated)" />
                        <TextBox Text="{Binding InputModesText}" PlaceholderText="application/json" />
                      </StackPanel>
                      <StackPanel Grid.Column="2" Spacing="4">
                        <TextBlock Classes="field-label" Text="Output Modes (comma-separated)" />
                        <TextBox Text="{Binding OutputModesText}" PlaceholderText="application/json" />
                      </StackPanel>
                    </Grid>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <!-- Workday Config -->
      <Border Classes="card">
        <StackPanel Spacing="12">
          <DockPanel>
            <Button DockPanel.Dock="Right" Classes="add" Content="+ Add Mapping"
                    Command="{Binding AddWorkdayConfigEntryCommand}" VerticalAlignment="Top" />
            <StackPanel>
              <TextBlock Classes="section-header" Text="Workday Config" />
              <TextBlock Classes="section-desc" Text="Map skills to Workday resources, execution modes, and securable items." />
            </StackPanel>
          </DockPanel>

          <ItemsControl ItemsSource="{Binding WorkdayConfig}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:AgentSkillResourceViewModel">
                <Border Classes="card-nested">
                  <StackPanel Spacing="10">
                    <DockPanel>
                      <Button DockPanel.Dock="Right" Classes="remove" Content="Remove"
                              Command="{Binding #EditorRoot.((vm:DefinitionEditorViewModel)DataContext).RemoveWorkdayConfigEntryCommand}"
                              CommandParameter="{Binding}" />
                      <TextBlock Classes="card-title" Text="Skill Resource Mapping" VerticalAlignment="Center" />
                    </DockPanel>

                    <Grid ColumnDefinitions="*,12,*">
                      <StackPanel Spacing="4">
                        <TextBlock Classes="field-label" Text="Skill *" />
                        <ComboBox ItemsSource="{Binding AvailableSkills}"
                                  SelectedValue="{Binding SkillId}"
                                  SelectedValueBinding="{Binding Id}"
                                  DisplayMemberBinding="{Binding Id}"
                                  PlaceholderText="Select a skill..."
                                  HorizontalAlignment="Stretch" />
                      </StackPanel>
                      <StackPanel Grid.Column="2" Spacing="4">
                        <TextBlock Classes="field-label" Text="Execution Mode *" />
                        <ComboBox ItemsSource="{Binding ExecutionModeOptions}"
                                  SelectedItem="{Binding SelectedExecutionMode}"
                                  PlaceholderText="Select mode..."
                                  HorizontalAlignment="Stretch" />
                      </StackPanel>
                    </Grid>

                    <!-- Workday Resources -->
                    <DockPanel Margin="0,4,0,0">
                      <Button DockPanel.Dock="Right" Classes="add" Content="+ Resource"
                              Command="{Binding AddWorkdayResourceCommand}" VerticalAlignment="Top" />
                      <TextBlock Classes="card-title" Text="Workday Resources" VerticalAlignment="Center" />
                    </DockPanel>

                    <ItemsControl ItemsSource="{Binding WorkdayResources}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:WorkdayResourceViewModel">
                          <Border Classes="card-inner">
                            <StackPanel Spacing="8">
                              <DockPanel>
                                <Button DockPanel.Dock="Right" Classes="remove" Content="Remove"
                                        Command="{Binding $parent[ItemsControl].((vm:AgentSkillResourceViewModel)DataContext).RemoveWorkdayResourceCommand}"
                                        CommandParameter="{Binding}" />
                                <TextBlock Classes="card-title" Text="Resource" VerticalAlignment="Center" />
                              </DockPanel>

                              <Grid ColumnDefinitions="*,12,*">
                                <StackPanel Spacing="4">
                                  <TextBlock Classes="field-label" Text="Tool Name *" />
                                  <TextBox Text="{Binding ToolName}" PlaceholderText="e.g. Get_Workers" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="4">
                                  <TextBlock Classes="field-label" Text="Agent Resource ID" />
                                  <TextBox Text="{Binding AgentResourceId}" PlaceholderText="Workday tool WID" />
                                </StackPanel>
                              </Grid>

                              <StackPanel Spacing="4">
                                <TextBlock Classes="field-label" Text="Description" />
                                <TextBox Text="{Binding Description}" PlaceholderText="What this tool does" />
                              </StackPanel>

                              <!-- Securable Items -->
                              <DockPanel Margin="0,4,0,0">
                                <Button DockPanel.Dock="Right" Classes="add" Content="+ Item"
                                        Command="{Binding AddToolCommand}" VerticalAlignment="Top" />
                                <TextBlock Classes="field-label" Text="Securable Items (SOAP Ops, REST Ops, Data Sources, etc.)"
                                           VerticalAlignment="Center" />
                              </DockPanel>

                              <ItemsControl ItemsSource="{Binding Tools}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:SecurableItemViewModel">
                                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,4">
                                      <TextBox Text="{Binding Id}" PlaceholderText="Workday securable item ID"
                                               Width="420" />
                                      <Button Classes="remove" Content="Remove"
                                              Command="{Binding $parent[ItemsControl].((vm:WorkdayResourceViewModel)DataContext).RemoveToolCommand}"
                                              CommandParameter="{Binding}" />
                                    </StackPanel>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </StackPanel>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <!-- Optional Fields -->
      <Border Classes="card">
        <StackPanel Spacing="12">
          <TextBlock Classes="section-header" Text="Optional Fields" />

          <StackPanel Spacing="4">
            <TextBlock Classes="field-label" Text="Overview" />
            <TextBox Text="{Binding Overview}" PlaceholderText="Summary display text"
                     AcceptsReturn="True" TextWrapping="Wrap" Height="56" />
          </StackPanel>

          <Grid ColumnDefinitions="*,16,*">
            <StackPanel Spacing="4">
              <TextBlock Classes="field-label" Text="Icon URL" />
              <TextBox Text="{Binding IconUrl}" PlaceholderText="https://..." />
            </StackPanel>
            <StackPanel Grid.Column="2" Spacing="4">
              <TextBlock Classes="field-label" Text="Documentation URL" />
              <TextBox Text="{Binding DocumentationUrl}" PlaceholderText="https://..." />
            </StackPanel>
          </Grid>

          <Grid ColumnDefinitions="*,16,*">
            <StackPanel Spacing="4">
              <TextBlock Classes="field-label" Text="External Agent ID" />
              <TextBox Text="{Binding ExternalAgentId}" PlaceholderText="Partner system identifier" />
            </StackPanel>
            <StackPanel Grid.Column="2" Spacing="4">
              <TextBlock Classes="field-label" Text="External Tenant ID" />
              <TextBox Text="{Binding ExternalTenantId}" PlaceholderText="Tenant locator" />
            </StackPanel>
          </Grid>

          <Grid ColumnDefinitions="*,16,*">
            <StackPanel Spacing="4">
              <TextBlock Classes="field-label" Text="Default Input Modes" />
              <TextBox Text="{Binding DefaultInputModesText}" PlaceholderText="application/json (comma-separated)" />
            </StackPanel>
            <StackPanel Grid.Column="2" Spacing="4">
              <TextBlock Classes="field-label" Text="Default Output Modes" />
              <TextBox Text="{Binding DefaultOutputModesText}" PlaceholderText="application/json (comma-separated)" />
            </StackPanel>
          </Grid>

          <CheckBox Content="Supports Authenticated Extended Card"
                    IsChecked="{Binding SupportsAuthenticatedExtendedCard}" />
        </StackPanel>
      </Border>

      <!-- Validation -->
      <Border Classes="card">
        <StackPanel Spacing="8">
          <StackPanel Orientation="Horizontal" Spacing="12">
            <Button Classes="primary" Content="Validate" Command="{Binding ValidateCommand}" />
            <TextBlock Classes="status-success" Text="Definition is valid"
                       VerticalAlignment="Center"
                       IsVisible="{Binding IsValid}" />
          </StackPanel>

          <TextBox Classes="mono" Text="{Binding ValidationErrors}" IsReadOnly="True"
                   AcceptsReturn="True" TextWrapping="Wrap" MaxHeight="200"
                   IsVisible="{Binding ValidationErrors, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                   Foreground="Red" />
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>

</UserControl>
