<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AsorAssistant.App.ViewModels"
             x:Class="AsorAssistant.App.Views.DefinitionEditorView"
             x:DataType="vm:DefinitionEditorViewModel"
             x:Name="EditorRoot">

  <DockPanel>
    <!-- Page Header -->
    <Border DockPanel.Dock="Top" Classes="page-header">
      <DockPanel>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <Border Classes="badge-success" IsVisible="{Binding IsValid}">
            <TextBlock Text="✓ Valid" FontSize="10" Foreground="{StaticResource AppSuccessBrush}" FontWeight="SemiBold" />
          </Border>
          <Border Classes="badge-error"
                  IsVisible="{Binding ValidationErrors, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <TextBlock Text="✕ Invalid" FontSize="10" Foreground="{StaticResource AppErrorBrush}" FontWeight="SemiBold" />
          </Border>

          <Button Classes="action" Content="Validate" Command="{Binding ValidateCommand}"
                  ToolTip.Tip="Check definition against ASOR v1.2 spec." />
          <Button Classes="action" Content="Save Draft"
                  ToolTip.Tip="Save current definition as a local draft.">
            <Button.Flyout>
              <Flyout Placement="BottomEdgeAlignedRight">
                <StackPanel Spacing="8" Width="280">
                  <TextBlock Text="Save Draft" FontWeight="SemiBold" />
                  <TextBox Text="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).DraftManager.DraftName}"
                           PlaceholderText="Draft name" />
                  <Button Classes="action-primary" Content="Save" HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Center"
                          Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).DraftManager.SaveCommand}" />
                </StackPanel>
              </Flyout>
            </Button.Flyout>
          </Button>
          <Button Classes="action-primary" Content="Register"
                  Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).OpenRegistrationPanelCommand}"
                  ToolTip.Tip="Open registration panel to POST to Workday ASOR." />
        </StackPanel>

        <StackPanel>
          <TextBlock Classes="page-title" Text="Agent Definition" />
          <TextBlock Classes="page-subtitle" Text="Define an external agent for the Workday Agent System of Record." />
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- Validation Errors -->
    <Border DockPanel.Dock="Top" Padding="28,10" Background="#18d95555"
            BorderBrush="{StaticResource AppBorderSubtleBrush}" BorderThickness="0,0,0,1"
            IsVisible="{Binding ValidationErrors, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
      <StackPanel Spacing="2">
        <TextBlock Text="Validation Errors" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource AppErrorBrush}" />
        <TextBlock Text="{Binding ValidationErrors}" FontSize="11" Foreground="{StaticResource AppErrorBrush}"
                   TextWrapping="Wrap" />
      </StackPanel>
    </Border>

    <!-- Editor Body -->
    <ScrollViewer Padding="28,20,28,48">
      <StackPanel Spacing="0" MaxWidth="960">

        <!-- IDENTITY -->
        <TextBlock Classes="section-header" Text="Identity" />
        <TextBlock Classes="section-desc" Text="Core fields that appear in the Workday agent catalog." />

        <StackPanel Spacing="12">
          <StackPanel Spacing="3">
            <TextBlock Classes="field-label" Text="NAME" />
            <TextBox Text="{Binding Name}" PlaceholderText="Human-readable agent name" />
            <TextBlock Classes="helper" Text="Display name shown to Workday admins and users." />
          </StackPanel>

          <StackPanel Spacing="3">
            <TextBlock Classes="field-label" Text="DESCRIPTION" />
            <TextBox Text="{Binding Description}" PlaceholderText="What this agent does — helps users and other agents understand its capabilities."
                     AcceptsReturn="True" TextWrapping="Wrap" Height="72" />
          </StackPanel>

          <Grid ColumnDefinitions="*,16,240">
            <StackPanel Spacing="3">
              <TextBlock Classes="field-label" Text="URL" />
              <TextBox Text="{Binding Url}" PlaceholderText="https://agents.example.com/my-agent" />
              <TextBlock Classes="helper" Text="The publicly reachable endpoint Workday will call." />
            </StackPanel>
            <StackPanel Grid.Column="2" Spacing="3">
              <TextBlock Classes="field-label" Text="VERSION" />
              <TextBox Text="{Binding Version}" PlaceholderText="1.0.0" />
              <TextBlock Classes="helper" Text="Semver recommended." />
            </StackPanel>
          </Grid>
        </StackPanel>

        <Separator Classes="section-divider" />

        <!-- PROVIDER + PLATFORM -->
        <TextBlock Classes="section-header" Text="Provider &amp; Platform" />
        <TextBlock Classes="section-desc" Text="Who built this agent and what platform it runs on. Select 'Other' to enter a custom ID." />

        <Grid ColumnDefinitions="*,16,*">
          <StackPanel Spacing="3">
            <TextBlock Classes="field-label" Text="PROVIDER" />
            <ComboBox ItemsSource="{Binding ProviderOptions}"
                      SelectedValue="{Binding SelectedProviderId}"
                      SelectedValueBinding="{Binding Id}"
                      DisplayMemberBinding="{Binding Name}"
                      PlaceholderText="Select provider..."
                      HorizontalAlignment="Stretch" />
            <TextBox Text="{Binding CustomProviderId}" PlaceholderText="Custom provider ID"
                     IsVisible="{Binding SelectedProviderId, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                     Margin="0,4,0,0" />
            <TextBlock Classes="helper" Text="The organisation that built or manages this agent." />
          </StackPanel>
          <StackPanel Grid.Column="2" Spacing="3">
            <TextBlock Classes="field-label" Text="PLATFORM" />
            <ComboBox ItemsSource="{Binding PlatformOptions}"
                      SelectedValue="{Binding SelectedPlatformId}"
                      SelectedValueBinding="{Binding Id}"
                      DisplayMemberBinding="{Binding Name}"
                      PlaceholderText="Select platform..."
                      HorizontalAlignment="Stretch" />
            <TextBox Text="{Binding CustomPlatformId}" PlaceholderText="Custom platform ID"
                     IsVisible="{Binding SelectedPlatformId, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                     Margin="0,4,0,0" />
            <TextBlock Classes="helper" Text="The runtime or framework the agent is deployed on." />
          </StackPanel>
        </Grid>

        <Separator Classes="section-divider" />

        <!-- CAPABILITIES -->
        <TextBlock Classes="section-header" Text="Capabilities" />
        <TextBlock Classes="section-desc" Text="Feature flags. Leave disabled unless your agent actively supports these." />

        <StackPanel Spacing="8">
          <ToggleSwitch Content="Push Notifications" IsChecked="{Binding PushNotifications}"
                        OnContent="Enabled" OffContent="Disabled"
                        ToolTip.Tip="Agent can send async updates to Workday without polling." />
          <ToggleSwitch Content="Streaming (SSE)" IsChecked="{Binding Streaming}"
                        OnContent="Enabled" OffContent="Disabled"
                        ToolTip.Tip="Agent supports Server-Sent Events for real-time streaming." />
          <ToggleSwitch Content="State Transition History" IsChecked="{Binding StateTransitionHistory}"
                        OnContent="Enabled" OffContent="Disabled"
                        ToolTip.Tip="Agent tracks and exposes task state transitions." />
        </StackPanel>

        <Separator Classes="section-divider" />

        <!-- SKILLS -->
        <DockPanel Margin="0,0,0,6">
          <Button DockPanel.Dock="Right" Classes="action-add" Content="+ Add Skill"
                  Command="{Binding AddSkillCommand}" VerticalAlignment="Top" />
          <StackPanel>
            <TextBlock Classes="section-header" Text="Skills" />
            <TextBlock Classes="section-desc" Text="At least one skill is required. Each defines a discrete capability the agent offers." />
          </StackPanel>
        </DockPanel>

        <ItemsControl ItemsSource="{Binding Skills}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:SkillViewModel">
              <Border Classes="surface">
                <Expander IsExpanded="True" HorizontalAlignment="Stretch">
                  <Expander.Header>
                    <DockPanel HorizontalAlignment="Stretch">
                      <Button DockPanel.Dock="Right" Classes="action-subtle" Content="Remove"
                              Command="{Binding #EditorRoot.((vm:DefinitionEditorViewModel)DataContext).RemoveSkillCommand}"
                              CommandParameter="{Binding}" />
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Classes="card-title" Text="{Binding Id, FallbackValue='New Skill'}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Name}" Foreground="{StaticResource AppTextMutedBrush}" FontSize="12"
                                   VerticalAlignment="Center" />
                      </StackPanel>
                    </DockPanel>
                  </Expander.Header>

                  <StackPanel Spacing="12" Margin="0,10,0,0">
                    <Grid ColumnDefinitions="220,16,*">
                      <StackPanel Spacing="3">
                        <TextBlock Classes="field-label" Text="ID" />
                        <TextBox Text="{Binding Id}" PlaceholderText="unique-skill-id" />
                        <TextBlock Classes="helper" Text="Stable identifier used in API calls." />
                      </StackPanel>
                      <StackPanel Grid.Column="2" Spacing="3">
                        <TextBlock Classes="field-label" Text="NAME" />
                        <TextBox Text="{Binding Name}" PlaceholderText="Human-readable skill name" />
                      </StackPanel>
                    </Grid>

                    <StackPanel Spacing="3">
                      <TextBlock Classes="field-label" Text="DESCRIPTION" />
                      <TextBox Text="{Binding Description}" PlaceholderText="What this skill does"
                               AcceptsReturn="True" TextWrapping="Wrap" Height="48" />
                    </StackPanel>

                    <StackPanel Spacing="3">
                      <TextBlock Classes="field-label" Text="TAGS (comma-separated)" />
                      <TextBox Text="{Binding TagsText}" PlaceholderText="tag1, tag2, tag3" />
                      <TextBlock Classes="helper" Text="Classification keywords to help Workday categorise this skill." />
                    </StackPanel>

                    <Grid ColumnDefinitions="*,16,*">
                      <StackPanel Spacing="3">
                        <TextBlock Classes="field-label" Text="INPUT MODES (comma-separated)" />
                        <TextBox Text="{Binding InputModesText}" PlaceholderText="application/json" />
                      </StackPanel>
                      <StackPanel Grid.Column="2" Spacing="3">
                        <TextBlock Classes="field-label" Text="OUTPUT MODES (comma-separated)" />
                        <TextBox Text="{Binding OutputModesText}" PlaceholderText="application/json" />
                      </StackPanel>
                    </Grid>
                  </StackPanel>
                </Expander>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Separator Classes="section-divider" />

        <!-- WORKDAY CONFIG -->
        <DockPanel Margin="0,0,0,6">
          <Button DockPanel.Dock="Right" Classes="action-add" Content="+ Add Mapping"
                  Command="{Binding AddWorkdayConfigEntryCommand}" VerticalAlignment="Top" />
          <StackPanel>
            <TextBlock Classes="section-header" Text="Workday Config" />
            <TextBlock Classes="section-desc" Text="Map skills to Workday resources, execution modes, and securable items." />
          </StackPanel>
        </DockPanel>

        <ItemsControl ItemsSource="{Binding WorkdayConfig}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:AgentSkillResourceViewModel">
              <Border Classes="surface">
                <Expander IsExpanded="True" HorizontalAlignment="Stretch">
                  <Expander.Header>
                    <DockPanel HorizontalAlignment="Stretch">
                      <Button DockPanel.Dock="Right" Classes="action-subtle" Content="Remove"
                              Command="{Binding #EditorRoot.((vm:DefinitionEditorViewModel)DataContext).RemoveWorkdayConfigEntryCommand}"
                              CommandParameter="{Binding}" />
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Classes="card-title" Text="{Binding SkillId, FallbackValue='Unmapped'}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding SelectedExecutionMode}" Foreground="{StaticResource AppTextMutedBrush}" FontSize="11"
                                   VerticalAlignment="Center" />
                      </StackPanel>
                    </DockPanel>
                  </Expander.Header>

                  <StackPanel Spacing="12" Margin="0,10,0,0">
                    <Grid ColumnDefinitions="*,16,*">
                      <StackPanel Spacing="3">
                        <TextBlock Classes="field-label" Text="SKILL" />
                        <ComboBox ItemsSource="{Binding AvailableSkills}"
                                  SelectedValue="{Binding SkillId}"
                                  SelectedValueBinding="{Binding Id}"
                                  DisplayMemberBinding="{Binding Id}"
                                  PlaceholderText="Select skill..."
                                  HorizontalAlignment="Stretch" />
                      </StackPanel>
                      <StackPanel Grid.Column="2" Spacing="3">
                        <TextBlock Classes="field-label" Text="EXECUTION MODE" />
                        <ComboBox ItemsSource="{Binding ExecutionModeOptions}"
                                  SelectedItem="{Binding SelectedExecutionMode}"
                                  PlaceholderText="Select mode..."
                                  HorizontalAlignment="Stretch" />
                        <TextBlock Classes="helper" Text="Ambient = no human invocation. Delegate = human-triggered." />
                      </StackPanel>
                    </Grid>

                    <!-- Resources -->
                    <DockPanel Margin="0,4,0,0">
                      <Button DockPanel.Dock="Right" Classes="action-add" Content="+ Resource"
                              Command="{Binding AddWorkdayResourceCommand}" VerticalAlignment="Top" />
                      <TextBlock Classes="card-title" Text="Resources" VerticalAlignment="Center" />
                    </DockPanel>

                    <ItemsControl ItemsSource="{Binding WorkdayResources}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:WorkdayResourceViewModel">
                          <Border Classes="surface-inner">
                            <StackPanel Spacing="10">
                              <DockPanel>
                                <Button DockPanel.Dock="Right" Classes="action-subtle" Content="Remove"
                                        Command="{Binding $parent[ItemsControl].((vm:AgentSkillResourceViewModel)DataContext).RemoveWorkdayResourceCommand}"
                                        CommandParameter="{Binding}" />
                                <TextBlock Classes="card-title"
                                           Text="{Binding ToolName, FallbackValue='New Resource'}"
                                           VerticalAlignment="Center" />
                              </DockPanel>

                              <Grid ColumnDefinitions="*,16,*">
                                <StackPanel Spacing="3">
                                  <TextBlock Classes="field-label" Text="TOOL NAME" />
                                  <TextBox Text="{Binding ToolName}" PlaceholderText="e.g. Get_Workers" />
                                  <TextBlock Classes="helper" Text="The endpoint or task this tool represents." />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="3">
                                  <TextBlock Classes="field-label" Text="AGENT RESOURCE ID" />
                                  <TextBox Text="{Binding AgentResourceId}" PlaceholderText="Workday tool WID" />
                                  <TextBlock Classes="helper" Text="Use Lookups tab to find WIDs." />
                                </StackPanel>
                              </Grid>

                              <StackPanel Spacing="3">
                                <TextBlock Classes="field-label" Text="DESCRIPTION" />
                                <TextBox Text="{Binding Description}" PlaceholderText="What this tool does" />
                              </StackPanel>

                              <!-- Securable Items -->
                              <DockPanel Margin="0,4,0,0">
                                <Button DockPanel.Dock="Right" Classes="action-add" Content="+ Item"
                                        Command="{Binding AddToolCommand}" VerticalAlignment="Top" />
                                <TextBlock Classes="field-label" Text="SECURABLE ITEMS"
                                           VerticalAlignment="Center" ToolTip.Tip="SOAP Ops, REST Ops, Data Sources, CRF Fields, etc." />
                              </DockPanel>

                              <ItemsControl ItemsSource="{Binding Tools}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate x:DataType="vm:SecurableItemViewModel">
                                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,4">
                                      <TextBox Text="{Binding Id}" PlaceholderText="Securable item WID" Width="420" />
                                      <Button Classes="action-subtle" Content="✕"
                                              Command="{Binding $parent[ItemsControl].((vm:WorkdayResourceViewModel)DataContext).RemoveToolCommand}"
                                              CommandParameter="{Binding}" />
                                    </StackPanel>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </StackPanel>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Expander>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Separator Classes="section-divider" />

        <!-- OPTIONAL FIELDS -->
        <Expander IsExpanded="False" HorizontalAlignment="Stretch">
          <Expander.Header>
            <StackPanel>
              <TextBlock Classes="section-header" Text="Optional Fields" />
              <TextBlock FontSize="11" Text="Overview, URLs, external IDs, MIME types"
                         Foreground="{StaticResource AppTextMutedBrush}" />
            </StackPanel>
          </Expander.Header>

          <StackPanel Spacing="12" Margin="0,10,0,0">
            <StackPanel Spacing="3">
              <TextBlock Classes="field-label" Text="OVERVIEW" />
              <TextBox Text="{Binding Overview}" PlaceholderText="Summary display text"
                       AcceptsReturn="True" TextWrapping="Wrap" Height="48" />
            </StackPanel>

            <Grid ColumnDefinitions="*,16,*">
              <StackPanel Spacing="3">
                <TextBlock Classes="field-label" Text="ICON URL" />
                <TextBox Text="{Binding IconUrl}" PlaceholderText="https://..." />
              </StackPanel>
              <StackPanel Grid.Column="2" Spacing="3">
                <TextBlock Classes="field-label" Text="DOCUMENTATION URL" />
                <TextBox Text="{Binding DocumentationUrl}" PlaceholderText="https://..." />
              </StackPanel>
            </Grid>

            <Grid ColumnDefinitions="*,16,*">
              <StackPanel Spacing="3">
                <TextBlock Classes="field-label" Text="EXTERNAL AGENT ID" />
                <TextBox Text="{Binding ExternalAgentId}" PlaceholderText="Partner system identifier" />
              </StackPanel>
              <StackPanel Grid.Column="2" Spacing="3">
                <TextBlock Classes="field-label" Text="EXTERNAL TENANT ID" />
                <TextBox Text="{Binding ExternalTenantId}" PlaceholderText="Tenant locator" />
              </StackPanel>
            </Grid>

            <Grid ColumnDefinitions="*,16,*">
              <StackPanel Spacing="3">
                <TextBlock Classes="field-label" Text="DEFAULT INPUT MODES (comma-separated)" />
                <TextBox Text="{Binding DefaultInputModesText}" PlaceholderText="application/json" />
              </StackPanel>
              <StackPanel Grid.Column="2" Spacing="3">
                <TextBlock Classes="field-label" Text="DEFAULT OUTPUT MODES (comma-separated)" />
                <TextBox Text="{Binding DefaultOutputModesText}" PlaceholderText="application/json" />
              </StackPanel>
            </Grid>

            <ToggleSwitch Content="Supports Authenticated Extended Card"
                          IsChecked="{Binding SupportsAuthenticatedExtendedCard}"
                          OnContent="Yes" OffContent="No" />
          </StackPanel>
        </Expander>

      </StackPanel>
    </ScrollViewer>
  </DockPanel>

</UserControl>
