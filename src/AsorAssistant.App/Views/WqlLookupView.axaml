<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AsorAssistant.App.ViewModels"
             x:Class="AsorAssistant.App.Views.WqlLookupView"
             x:DataType="vm:WqlLookupViewModel">

  <DockPanel Margin="16">
    <StackPanel DockPanel.Dock="Top" Spacing="12" MaxWidth="600" HorizontalAlignment="Left">

      <TextBlock Text="WQL Service Operation Lookup" FontSize="20" FontWeight="Bold" />

      <StackPanel Spacing="8">
        <TextBlock Text="Bearer Token *" />
        <TextBox Text="{Binding BearerToken}" PlaceholderText="Paste bearer token"
                 PasswordChar="*" RevealPassword="False" />
      </StackPanel>

      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button Content="Lookup SOAP Operations" Command="{Binding LookupSoapCommand}"
                IsEnabled="{Binding !IsLoading}" />
        <Button Content="Lookup REST Operations" Command="{Binding LookupRestCommand}"
                IsEnabled="{Binding !IsLoading}" />
      </StackPanel>

      <TextBlock Text="{Binding StatusMessage}" Foreground="Gray" />
    </StackPanel>

    <!-- Results -->
    <StackPanel Margin="0,12,0,0" Spacing="8">
      <StackPanel Spacing="8">
        <TextBlock Text="Filter" />
        <TextBox Text="{Binding FilterText}" PlaceholderText="Type to filter results..." />
      </StackPanel>

      <DataGrid ItemsSource="{Binding Results}"
                SelectedItem="{Binding SelectedResult}"
                AutoGenerateColumns="False"
                IsReadOnly="True"
                Height="350"
                SelectionMode="Single">
        <DataGrid.Columns>
          <DataGridTextColumn Header="Operation" Binding="{Binding Name}" Width="*" />
          <DataGridTextColumn Header="Workday ID" Binding="{Binding WorkdayId}" Width="300" />
          <DataGridTextColumn Header="Service" Binding="{Binding ServiceName}" Width="200" />
          <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="60" />
        </DataGrid.Columns>
      </DataGrid>

      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button Content="Copy WID" Command="{Binding CopyWidCommand}" />
      </StackPanel>
    </StackPanel>
  </DockPanel>

</UserControl>
