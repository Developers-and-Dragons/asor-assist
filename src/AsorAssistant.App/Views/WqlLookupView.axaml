<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AsorAssistant.App.ViewModels"
             x:Class="AsorAssistant.App.Views.WqlLookupView"
             x:DataType="vm:WqlLookupViewModel">

  <DockPanel>
    <!-- Page Header -->
    <Border DockPanel.Dock="Top" Classes="page-header">
      <DockPanel>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <TextBlock Text="{Binding StatusMessage}" FontSize="11"
                     Foreground="{DynamicResource AppTextMutedBrush}" VerticalAlignment="Center"
                     IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
          <Button Classes="action" Content="SOAP Operations" Command="{Binding LookupSoapCommand}"
                  IsEnabled="{Binding !IsLoading}"
                  ToolTip.Tip="Query publicWebServices for SOAP service operation WIDs." />
          <Button Classes="action" Content="REST Operations" Command="{Binding LookupRestCommand}"
                  IsEnabled="{Binding !IsLoading}"
                  ToolTip.Tip="Query allPublicServiceOperations for REST WIDs." />
          <Button Classes="action" Content="Copy WID" Command="{Binding CopyWidCommand}"
                  CommandParameter="{Binding $parent[TopLevel].Clipboard}"
                  ToolTip.Tip="Copy the selected Workday ID to clipboard." />
        </StackPanel>
        <StackPanel>
          <TextBlock Classes="page-title" Text="Service Operation Lookups" />
          <TextBlock Classes="page-subtitle" Text="Find Workday IDs (WIDs) for Agent Resource and Securable Item fields." />
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- Body -->
    <DockPanel Margin="28,16">
      <!-- Filter + result type -->
      <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
        <TextBlock DockPanel.Dock="Right" Text="{Binding ResultTypeLabel}"
                   Foreground="{DynamicResource AppTextMutedBrush}" FontSize="12" FontWeight="SemiBold"
                   VerticalAlignment="Center"
                   IsVisible="{Binding ResultTypeLabel, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        <TextBox Text="{Binding FilterText}" PlaceholderText="Filter results..." Margin="0,0,16,0" />
      </DockPanel>

      <!-- Results table fills space -->
      <DataGrid ItemsSource="{Binding Results}"
                SelectedItem="{Binding SelectedResult}"
                AutoGenerateColumns="False"
                IsReadOnly="True"
                SelectionMode="Single"
                GridLinesVisibility="Horizontal"
                BorderThickness="1"
                BorderBrush="{DynamicResource AppBorderSubtleBrush}"
                CornerRadius="8">
        <DataGrid.Columns>
          <DataGridTextColumn Header="Operation" Binding="{Binding Name}" Width="*" />
          <DataGridTextColumn Header="Workday ID" Binding="{Binding WorkdayId}" Width="300" />
          <DataGridTextColumn Header="Service" Binding="{Binding ServiceName}" Width="200"
                              IsVisible="{Binding $parent[UserControl].((vm:WqlLookupViewModel)DataContext).ShowServiceColumn}" />
        </DataGrid.Columns>
      </DataGrid>
    </DockPanel>
  </DockPanel>

</UserControl>
