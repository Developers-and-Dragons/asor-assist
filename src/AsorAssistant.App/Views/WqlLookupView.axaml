<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AsorAssistant.App.ViewModels"
             x:Class="AsorAssistant.App.Views.WqlLookupView"
             x:DataType="vm:WqlLookupViewModel">

  <DockPanel Margin="24,20">
    <!-- Header -->
    <TextBlock DockPanel.Dock="Top" Classes="page-title" Text="WQL Lookup" Margin="0,0,0,20" />

    <StackPanel Spacing="16">

      <!-- Actions -->
      <StackPanel Spacing="8">
        <TextBlock Classes="section-header" Text="Service Operation Lookup" />
        <TextBlock Classes="section-desc" Text="Search for SOAP or REST service operation WIDs. Set your bearer token via the 🔑 button in the nav rail." />

        <StackPanel Orientation="Horizontal" Spacing="8">
          <Button Classes="action-primary" Content="SOAP Operations" Command="{Binding LookupSoapCommand}"
                  IsEnabled="{Binding !IsLoading}" />
          <Button Classes="action" Content="REST Operations" Command="{Binding LookupRestCommand}"
                  IsEnabled="{Binding !IsLoading}" />
        </StackPanel>
      </StackPanel>

      <Separator Classes="section-divider" />

      <!-- Results -->
      <DockPanel Margin="0,0,0,8">
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
          <TextBlock Text="{Binding StatusMessage}" FontSize="12" Opacity="0.5"
                     VerticalAlignment="Center"
                     IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBlock Classes="section-header" Text="Results" VerticalAlignment="Center" />
          <TextBlock Classes="section-header" Text="{Binding ResultTypeLabel}" Opacity="0.4"
                     VerticalAlignment="Center"
                     IsVisible="{Binding ResultTypeLabel, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        </StackPanel>
      </DockPanel>

      <TextBox Text="{Binding FilterText}" PlaceholderText="Filter results..." />

      <DataGrid ItemsSource="{Binding Results}"
                SelectedItem="{Binding SelectedResult}"
                AutoGenerateColumns="False"
                IsReadOnly="True"
                Height="380"
                SelectionMode="Single"
                GridLinesVisibility="Horizontal"
                BorderThickness="1"
                BorderBrush="#15ffffff"
                CornerRadius="6">
        <DataGrid.Columns>
          <DataGridTextColumn Header="Operation" Binding="{Binding Name}" Width="350" />
          <DataGridTextColumn Header="Workday ID" Binding="{Binding WorkdayId}" Width="280" />
          <DataGridTextColumn Header="Service" Binding="{Binding ServiceName}" Width="180"
                              IsVisible="{Binding $parent[UserControl].((vm:WqlLookupViewModel)DataContext).ShowServiceColumn}" />
        </DataGrid.Columns>
      </DataGrid>

      <Button Classes="action" Content="Copy Selected WID"
              Command="{Binding CopyWidCommand}"
              CommandParameter="{Binding $parent[TopLevel].Clipboard}" />
    </StackPanel>
  </DockPanel>

</UserControl>
