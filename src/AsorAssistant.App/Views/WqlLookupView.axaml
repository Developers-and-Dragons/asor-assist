<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AsorAssistant.App.ViewModels"
             x:Class="AsorAssistant.App.Views.WqlLookupView"
             x:DataType="vm:WqlLookupViewModel">

  <StackPanel Spacing="4" Margin="20,12">

    <!-- Auth + Actions -->
    <Border Classes="card">
      <StackPanel Spacing="12">
        <TextBlock Classes="section-header" Text="WQL Service Operation Lookup" />
        <TextBlock Classes="section-desc" Text="Search for SOAP or REST service operation WIDs to use in your Workday Config." />

        <StackPanel Spacing="4" MaxWidth="500">
          <TextBlock Classes="field-label" Text="Bearer Token *" />
          <TextBox Text="{Binding BearerToken}" PlaceholderText="Paste bearer token"
                   PasswordChar="*" RevealPassword="False" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="8">
          <Button Classes="primary" Content="SOAP Operations" Command="{Binding LookupSoapCommand}"
                  IsEnabled="{Binding !IsLoading}" />
          <Button Classes="add" Content="REST Operations" Command="{Binding LookupRestCommand}"
                  IsEnabled="{Binding !IsLoading}" />
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- Results -->
    <Border Classes="card">
      <StackPanel Spacing="12">
        <DockPanel>
          <TextBlock DockPanel.Dock="Right" Text="{Binding StatusMessage}"
                     Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                     VerticalAlignment="Center" FontSize="13"
                     IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
          <TextBlock Classes="section-header" Text="Results" />
        </DockPanel>

        <TextBox Text="{Binding FilterText}" PlaceholderText="Type to filter results..." />

        <DataGrid ItemsSource="{Binding Results}"
                  SelectedItem="{Binding SelectedResult}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Height="380"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  BorderThickness="1"
                  BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                  CornerRadius="6">
          <DataGrid.Columns>
            <DataGridTextColumn Header="Operation" Binding="{Binding Name}" Width="*" />
            <DataGridTextColumn Header="Workday ID" Binding="{Binding WorkdayId}" Width="280" />
            <DataGridTextColumn Header="Service" Binding="{Binding ServiceName}" Width="180" />
            <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="60" />
          </DataGrid.Columns>
        </DataGrid>

        <Button Classes="add" Content="Copy Selected WID" Command="{Binding CopyWidCommand}" />
      </StackPanel>
    </Border>

  </StackPanel>

</UserControl>
