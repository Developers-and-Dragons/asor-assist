<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AsorAssistant.App.ViewModels"
             xmlns:models="using:AsorAssistant.Application.Models"
             x:Class="AsorAssistant.App.Views.DraftManagerView"
             x:DataType="vm:DraftManagerViewModel">

  <DockPanel Margin="16">
    <!-- Save area -->
    <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="0,0,0,16">
      <TextBlock Text="Save Current Definition" FontSize="16" FontWeight="SemiBold" />
      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBox Text="{Binding DraftName}" PlaceholderText="Draft name" Width="300" />
        <Button Content="Save" Command="{Binding SaveCommand}" />
      </StackPanel>
    </StackPanel>

    <!-- Status -->
    <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusMessage}"
               Margin="0,8,0,0" Foreground="Gray" />

    <!-- Drafts list -->
    <StackPanel Spacing="8">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBlock Text="Saved Drafts" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
        <Button Content="Refresh" Command="{Binding RefreshListCommand}" />
      </StackPanel>

      <DataGrid ItemsSource="{Binding Drafts}"
                SelectedItem="{Binding SelectedDraft}"
                AutoGenerateColumns="False"
                IsReadOnly="True"
                Height="300"
                SelectionMode="Single">
        <DataGrid.Columns>
          <DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="*" />
          <DataGridTextColumn Header="Provider" Binding="{Binding Provider}" Width="150" />
          <DataGridTextColumn Header="Version" Binding="{Binding Version}" Width="100" />
          <DataGridTextColumn Header="Region" Binding="{Binding RegionName}" Width="80" />
          <DataGridTextColumn Header="Last Modified" Binding="{Binding LastModified, StringFormat='{}{0:g}'}" Width="160" />
        </DataGrid.Columns>
      </DataGrid>

      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button Content="Load" Command="{Binding LoadCommand}" />
        <Button Content="Duplicate" Command="{Binding DuplicateCommand}" />
        <Button Content="Delete" Command="{Binding DeleteCommand}" />
      </StackPanel>
    </StackPanel>
  </DockPanel>

</UserControl>
