<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AsorAssistant.App.ViewModels"
             xmlns:models="using:AsorAssistant.Core.Models"
             xmlns:domain="using:AsorAssistant.Domain.Models"
             x:Class="AsorAssistant.App.Views.DraftManagerView"
             x:DataType="vm:DraftManagerViewModel">

  <DockPanel>
    <!-- Page Header -->
    <Border DockPanel.Dock="Top" Classes="page-header">
      <DockPanel>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <TextBox Text="{Binding DraftName}" PlaceholderText="Draft name" Width="240" />
          <Button Classes="action-primary" Content="Save Current Draft" Command="{Binding SaveCommand}"
                  ToolTip.Tip="Save the current editor definition as a local draft." />
        </StackPanel>
        <StackPanel>
          <TextBlock Classes="page-title" Text="Drafts &amp; Remote Agents" />
          <TextBlock Classes="page-subtitle" Text="Manage local drafts or pull registered agents from a Workday tenant." />
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- Body: two-panel layout -->
    <ScrollViewer Padding="28,20,28,28">
      <StackPanel Spacing="0" MaxWidth="1100">

        <!-- LOCAL DRAFTS -->
        <TextBlock Classes="section-header" Text="Local Drafts" />
        <TextBlock Classes="section-desc" Text="Saved locally as JSON files. Connection details are not included." />

        <DataGrid ItemsSource="{Binding Drafts}"
                  SelectedItem="{Binding SelectedDraft}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Height="220"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  BorderThickness="1"
                  BorderBrush="{StaticResource AppBorderSubtleBrush}"
                  CornerRadius="8">
          <DataGrid.Columns>
            <DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="*" />
            <DataGridTextColumn Header="Provider" Binding="{Binding Provider}" Width="160" />
            <DataGridTextColumn Header="Version" Binding="{Binding Version}" Width="100" />
            <DataGridTextColumn Header="Region" Binding="{Binding RegionName}" Width="80" />
            <DataGridTextColumn Header="Last Modified" Binding="{Binding LastModified, StringFormat='{}{0:g}'}" Width="160" />
          </DataGrid.Columns>
        </DataGrid>

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,10,0,0">
          <Button Classes="action-primary" Content="Load into Editor" Command="{Binding LoadCommand}"
                  ToolTip.Tip="Load the selected draft, replacing the current definition." />
          <Button Classes="action" Content="Duplicate" Command="{Binding DuplicateCommand}" />
          <Button Classes="action-subtle" Content="Delete" Command="{Binding DeleteCommand}" />
          <Button Classes="action" Content="Refresh" Command="{Binding RefreshListCommand}" />
          <TextBlock Text="{Binding StatusMessage}" FontSize="11"
                     Foreground="{StaticResource AppTextMutedBrush}" VerticalAlignment="Center" Margin="8,0,0,0"
                     IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        </StackPanel>

        <Separator Classes="section-divider" />

        <!-- REMOTE AGENTS -->
        <TextBlock Classes="section-header" Text="Registered Agents" />
        <TextBlock Classes="section-desc" Text="Fetch agent definitions from a Workday tenant to view or edit them locally." />

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
          <ComboBox ItemsSource="{Binding Regions}"
                    SelectedItem="{Binding SelectedRegion}"
                    PlaceholderText="Select region..."
                    Width="160">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Name}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
          <Button Classes="action-primary" Content="Fetch from Tenant"
                  Command="{Binding FetchRemoteAgentsCommand}"
                  IsEnabled="{Binding !IsFetchingRemote}"
                  ToolTip.Tip="GET /asor/v1/agentDefinition — lists all registered agents in the selected region." />
          <TextBlock Text="{Binding RemoteStatusMessage}" FontSize="11"
                     Foreground="{StaticResource AppTextMutedBrush}" VerticalAlignment="Center" Margin="8,0,0,0"
                     IsVisible="{Binding RemoteStatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        </StackPanel>

        <DataGrid ItemsSource="{Binding RemoteAgents}"
                  SelectedItem="{Binding SelectedRemoteAgent}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Height="220"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  BorderThickness="1"
                  BorderBrush="{StaticResource AppBorderSubtleBrush}"
                  CornerRadius="8">
          <DataGrid.Columns>
            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
            <DataGridTextColumn Header="Provider" Binding="{Binding Provider.Descriptor}" Width="160" />
            <DataGridTextColumn Header="Platform" Binding="{Binding Platform.Descriptor}" Width="160" />
            <DataGridTextColumn Header="Version" Binding="{Binding Version}" Width="100" />
            <DataGridTextColumn Header="URL" Binding="{Binding Url}" Width="250" />
          </DataGrid.Columns>
        </DataGrid>

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,10,0,0">
          <Button Classes="action-primary" Content="Load into Editor" Command="{Binding LoadRemoteAgentCommand}"
                  ToolTip.Tip="Load this agent definition into the editor for viewing or editing." />
        </StackPanel>

      </StackPanel>
    </ScrollViewer>
  </DockPanel>

</UserControl>
