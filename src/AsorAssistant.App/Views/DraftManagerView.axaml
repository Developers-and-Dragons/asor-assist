<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AsorAssistant.App.ViewModels"
             xmlns:models="using:AsorAssistant.Core.Models"
             x:Class="AsorAssistant.App.Views.DraftManagerView"
             x:DataType="vm:DraftManagerViewModel">

  <DockPanel Margin="24,20">
    <!-- Header -->
    <TextBlock DockPanel.Dock="Top" Classes="page-title" Text="Saved Drafts" Margin="0,0,0,20" />

    <StackPanel Spacing="16" MaxWidth="900">

      <!-- Save current -->
      <StackPanel Spacing="8">
        <TextBlock Classes="section-header" Text="Save Current Definition" />
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBox Text="{Binding DraftName}" PlaceholderText="Draft name" Width="300" />
          <Button Classes="action-primary" Content="Save" Command="{Binding SaveCommand}" />
        </StackPanel>
      </StackPanel>

      <Separator Classes="section-divider" />

      <!-- Drafts list -->
      <DockPanel Margin="0,0,0,8">
        <Button DockPanel.Dock="Right" Classes="action" Content="Refresh"
                Command="{Binding RefreshListCommand}" />
        <TextBlock Classes="section-header" Text="All Drafts" VerticalAlignment="Center" />
      </DockPanel>

      <DataGrid ItemsSource="{Binding Drafts}"
                SelectedItem="{Binding SelectedDraft}"
                AutoGenerateColumns="False"
                IsReadOnly="True"
                Height="320"
                SelectionMode="Single"
                GridLinesVisibility="Horizontal"
                BorderThickness="1"
                BorderBrush="#15ffffff"
                CornerRadius="6">
        <DataGrid.Columns>
          <DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="*" />
          <DataGridTextColumn Header="Provider" Binding="{Binding Provider}" Width="140" />
          <DataGridTextColumn Header="Version" Binding="{Binding Version}" Width="80" />
          <DataGridTextColumn Header="Region" Binding="{Binding RegionName}" Width="60" />
          <DataGridTextColumn Header="Modified" Binding="{Binding LastModified, StringFormat='{}{0:g}'}" Width="140" />
        </DataGrid.Columns>
      </DataGrid>

      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button Classes="action-primary" Content="Load" Command="{Binding LoadCommand}" />
        <Button Classes="action" Content="Duplicate" Command="{Binding DuplicateCommand}" />
        <Button Classes="action-subtle" Content="Delete" Command="{Binding DeleteCommand}" />
      </StackPanel>

      <!-- Status -->
      <TextBlock Text="{Binding StatusMessage}" FontSize="12" Opacity="0.5"
                 IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
    </StackPanel>
  </DockPanel>

</UserControl>
