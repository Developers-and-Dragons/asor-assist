<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AsorAssistant.App.ViewModels"
             x:Class="AsorAssistant.App.Views.RegistrationView"
             x:DataType="vm:RegistrationViewModel">

  <DockPanel Margin="16">
    <StackPanel DockPanel.Dock="Top" Spacing="12" MaxWidth="600" HorizontalAlignment="Left">

      <TextBlock Text="Register Agent Definition" FontSize="20" FontWeight="Bold" />

      <StackPanel Spacing="8">
        <TextBlock Text="Region *" />
        <ComboBox ItemsSource="{Binding Regions}"
                  SelectedItem="{Binding SelectedRegion}"
                  PlaceholderText="Select region...">
          <ComboBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding Name}" />
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>
      </StackPanel>

      <StackPanel Spacing="8">
        <TextBlock Text="Tenant Name" />
        <TextBox Text="{Binding TenantName}" PlaceholderText="your-tenant-name" />
      </StackPanel>

      <StackPanel Spacing="8">
        <TextBlock Text="Bearer Token *" />
        <TextBox Text="{Binding BearerToken}" PlaceholderText="Paste bearer token"
                 PasswordChar="*" RevealPassword="False" />
      </StackPanel>

      <!-- URL Preview -->
      <StackPanel Spacing="4"
                  IsVisible="{Binding ResolvedUrl, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
        <TextBlock Text="Registration URL:" FontWeight="SemiBold" />
        <TextBlock Text="{Binding ResolvedUrl}" Foreground="Gray" FontFamily="Cascadia Mono, Consolas, monospace" />
      </StackPanel>

      <Button Content="Register" Command="{Binding RegisterCommand}"
              IsEnabled="{Binding !IsRegistering}" />

    </StackPanel>

    <!-- Response -->
    <StackPanel Margin="0,16,0,0" Spacing="8">
      <TextBlock Text="Response" FontSize="16" FontWeight="SemiBold"
                 IsVisible="{Binding ResponseText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
      <TextBox Text="{Binding ResponseText}" IsReadOnly="True"
               AcceptsReturn="True" TextWrapping="Wrap"
               FontFamily="Cascadia Mono, Consolas, monospace"
               FontSize="13"
               MaxHeight="400"
               IsVisible="{Binding ResponseText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
    </StackPanel>
  </DockPanel>

</UserControl>
