<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AsorAssistant.App.ViewModels"
             x:Class="AsorAssistant.App.Views.RegistrationView"
             x:DataType="vm:RegistrationViewModel">

  <ScrollViewer>
    <StackPanel Spacing="0">

      <!-- Header -->
      <DockPanel Margin="0,0,0,16">
        <Button DockPanel.Dock="Right" Classes="action-subtle" Content="✕"
                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).CloseRegistrationPanelCommand}"
                ToolTip.Tip="Close registration panel" />
        <TextBlock Classes="page-title" Text="Register" />
      </DockPanel>

      <TextBlock Classes="section-desc" Text="POST the current definition to Workday ASOR. Region and token are set in the connection bar above." />

      <!-- Token reminder -->
      <Border Classes="badge-warning" CornerRadius="4" Padding="8,6" Margin="0,0,0,12"
              IsVisible="{Binding !$parent[Window].((vm:MainWindowViewModel)DataContext).HasToken}">
        <TextBlock Text="⚠ Set a bearer token and region in the connection bar above."
                   FontSize="11" Foreground="{DynamicResource AppWarningBrush}" TextWrapping="Wrap" />
      </Border>

      <!-- URL Preview -->
      <Border Classes="surface-inner" Padding="10,8" Margin="0,0,0,12"
              IsVisible="{Binding ResolvedUrl, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
        <StackPanel Spacing="2">
          <TextBlock Classes="field-label" Text="ENDPOINT" />
          <TextBlock Text="{Binding ResolvedUrl}" Classes="mono" FontSize="11"
                     Foreground="{DynamicResource AppTextSecondaryBrush}" TextWrapping="Wrap" />
        </StackPanel>
      </Border>

      <Button Classes="action-primary" Content="Register Agent Definition"
              Command="{Binding RegisterCommand}"
              IsEnabled="{Binding !IsRegistering}"
              HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
              ToolTip.Tip="POST the current agent definition JSON to the Workday ASOR API." />

      <!-- Response -->
      <StackPanel Spacing="6" Margin="0,16,0,0"
                  IsVisible="{Binding ResponseText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
        <TextBlock Classes="field-label" Text="RESPONSE" />
        <TextBox Classes="mono" Text="{Binding ResponseText}" IsReadOnly="True"
                 AcceptsReturn="True" TextWrapping="Wrap" MaxHeight="400" />
      </StackPanel>

    </StackPanel>
  </ScrollViewer>

</UserControl>
