<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AsorAssistant.App.ViewModels"
             x:Class="AsorAssistant.App.Views.RegistrationView"
             x:DataType="vm:RegistrationViewModel">

  <ScrollViewer>
    <StackPanel Spacing="0">

      <!-- Header -->
      <DockPanel Margin="0,0,0,16">
        <Button DockPanel.Dock="Right" Classes="action-subtle" Content="✕"
                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).CloseRegistrationPanelCommand}"
                ToolTip.Tip="Close registration panel" />
        <TextBlock Classes="page-title" Text="Register" />
      </DockPanel>

      <!-- Connection Section -->
      <TextBlock Classes="section-header" Text="Connection" />
      <TextBlock Classes="section-desc" Text="Configure your Workday environment. This token is also used for WQL lookups." />
      <TextBlock Opacity="0.4" FontSize="11" Margin="0,2,0,6"
                 Text="Get a bearer token from Workday OAuth (API Client &gt; Generate Token). It is not saved to disk." />

      <StackPanel Spacing="10">
        <StackPanel Spacing="3">
          <TextBlock Classes="field-label" Text="REGION" />
          <ComboBox ItemsSource="{Binding Regions}"
                    SelectedItem="{Binding SelectedRegion}"
                    PlaceholderText="Select region..."
                    HorizontalAlignment="Stretch">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Name}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
          <TextBlock Opacity="0.4" FontSize="11" Text="Determines the ASOR endpoint: {region}.agent.workday.com" />
        </StackPanel>

        <StackPanel Spacing="3">
          <TextBlock Classes="field-label" Text="TENANT NAME" />
          <TextBox Text="{Binding TenantName}" PlaceholderText="your-tenant-name" />
          <TextBlock Opacity="0.4" FontSize="11" Text="Your Workday tenant identifier, as shown in your Workday URL." />
        </StackPanel>

        <StackPanel Spacing="3">
          <TextBlock Classes="field-label" Text="BEARER TOKEN" />
          <TextBox Text="{Binding BearerToken}" PlaceholderText="Paste bearer token"
                   PasswordChar="*" RevealPassword="False" />
          <TextBlock Opacity="0.4" FontSize="11" Text="Kept in memory only. You will need to re-enter it each session." />
        </StackPanel>
      </StackPanel>

      <Separator Classes="section-divider" />

      <!-- Registration Section -->
      <TextBlock Classes="section-header" Text="Submit" />

      <!-- URL Preview -->
      <Border Classes="surface-inner" Padding="10,8" Margin="0,8,0,12"
              IsVisible="{Binding ResolvedUrl, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
        <StackPanel Spacing="2">
          <TextBlock Classes="field-label" Text="ENDPOINT" />
          <TextBlock Text="{Binding ResolvedUrl}" Classes="mono" FontSize="11"
                     Opacity="0.6" TextWrapping="Wrap" />
        </StackPanel>
      </Border>

      <!-- Readiness check -->
      <StackPanel Spacing="4" Margin="0,0,0,12"
                  IsVisible="{Binding !IsConnectionConfigured}">
        <TextBlock Text="⚠ Missing configuration" FontSize="12" Foreground="#ffb080" FontWeight="SemiBold" />
        <TextBlock FontSize="11" Opacity="0.5" TextWrapping="Wrap">
          <Run Text="Select a region and enter a bearer token above to enable registration." />
        </TextBlock>
      </StackPanel>

      <Button Classes="action-primary" Content="Register Agent Definition"
              Command="{Binding RegisterCommand}"
              IsEnabled="{Binding !IsRegistering}"
              HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
              ToolTip.Tip="POST the current agent definition JSON to the Workday ASOR API." />

      <!-- Response -->
      <StackPanel Spacing="6" Margin="0,16,0,0"
                  IsVisible="{Binding ResponseText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
        <TextBlock Classes="field-label" Text="RESPONSE" />
        <TextBox Classes="mono" Text="{Binding ResponseText}" IsReadOnly="True"
                 AcceptsReturn="True" TextWrapping="Wrap" MaxHeight="300" />
      </StackPanel>

    </StackPanel>
  </ScrollViewer>

</UserControl>
