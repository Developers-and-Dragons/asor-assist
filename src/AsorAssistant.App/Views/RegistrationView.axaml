<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AsorAssistant.App.ViewModels"
             x:Class="AsorAssistant.App.Views.RegistrationView"
             x:DataType="vm:RegistrationViewModel">

  <ScrollViewer Padding="20,12">
    <StackPanel Spacing="4" MaxWidth="700" HorizontalAlignment="Left">

      <!-- Connection -->
      <Border Classes="card">
        <StackPanel Spacing="12">
          <TextBlock Classes="section-header" Text="Connection" />
          <TextBlock Classes="section-desc" Text="Select a region and provide authentication credentials." />

          <Grid ColumnDefinitions="*,16,*">
            <StackPanel Spacing="4">
              <TextBlock Classes="field-label" Text="Region *" />
              <ComboBox ItemsSource="{Binding Regions}"
                        SelectedItem="{Binding SelectedRegion}"
                        PlaceholderText="Select region..."
                        HorizontalAlignment="Stretch">
                <ComboBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding Name}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
            </StackPanel>
            <StackPanel Grid.Column="2" Spacing="4">
              <TextBlock Classes="field-label" Text="Tenant Name" />
              <TextBox Text="{Binding TenantName}" PlaceholderText="your-tenant-name" />
            </StackPanel>
          </Grid>

          <StackPanel Spacing="4">
            <TextBlock Classes="field-label" Text="Bearer Token *" />
            <TextBox Text="{Binding BearerToken}" PlaceholderText="Paste bearer token"
                     PasswordChar="*" RevealPassword="False" />
          </StackPanel>

          <!-- URL Preview -->
          <Border Classes="card-inner" Padding="12,8"
                  IsVisible="{Binding ResolvedUrl, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <StackPanel Spacing="2">
              <TextBlock Classes="field-label" Text="Registration URL" />
              <TextBlock Text="{Binding ResolvedUrl}" Classes="mono"
                         Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="13" />
            </StackPanel>
          </Border>
        </StackPanel>
      </Border>

      <!-- Action -->
      <Border Classes="card">
        <StackPanel Spacing="12">
          <Button Classes="primary" Content="Register Agent Definition"
                  Command="{Binding RegisterCommand}"
                  IsEnabled="{Binding !IsRegistering}" />
        </StackPanel>
      </Border>

      <!-- Response -->
      <Border Classes="card"
              IsVisible="{Binding ResponseText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
        <StackPanel Spacing="8">
          <TextBlock Classes="section-header" Text="Response" />
          <TextBox Classes="mono" Text="{Binding ResponseText}" IsReadOnly="True"
                   AcceptsReturn="True" TextWrapping="Wrap" MaxHeight="400" />
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>

</UserControl>
