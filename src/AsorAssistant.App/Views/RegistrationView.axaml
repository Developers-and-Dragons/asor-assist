<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AsorAssistant.App.ViewModels"
             x:Class="AsorAssistant.App.Views.RegistrationView"
             x:DataType="vm:RegistrationViewModel">

  <ScrollViewer>
    <StackPanel Spacing="16">

      <DockPanel>
        <Button DockPanel.Dock="Right" Classes="action-subtle" Content="✕"
                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ToggleRegistrationPanelCommand}" />
        <TextBlock Classes="page-title" Text="Register" />
      </DockPanel>

      <TextBlock Text="Submit this definition to the ASOR API."
                 FontSize="12" Opacity="0.5" />

      <StackPanel Spacing="3">
        <TextBlock Classes="field-label" Text="REGION" />
        <ComboBox ItemsSource="{Binding Regions}"
                  SelectedItem="{Binding SelectedRegion}"
                  PlaceholderText="Select region..."
                  HorizontalAlignment="Stretch">
          <ComboBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding Name}" />
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>
      </StackPanel>

      <StackPanel Spacing="3">
        <TextBlock Classes="field-label" Text="TENANT NAME" />
        <TextBox Text="{Binding TenantName}" PlaceholderText="your-tenant-name" />
      </StackPanel>

      <!-- URL Preview -->
      <Border Classes="surface-inner" Padding="10,8"
              IsVisible="{Binding ResolvedUrl, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
        <StackPanel Spacing="2">
          <TextBlock Classes="field-label" Text="ENDPOINT" />
          <TextBlock Text="{Binding ResolvedUrl}" Classes="mono" FontSize="11"
                     Opacity="0.6" TextWrapping="Wrap" />
        </StackPanel>
      </Border>

      <Button Classes="action-primary" Content="Register Agent"
              Command="{Binding RegisterCommand}"
              IsEnabled="{Binding !IsRegistering}"
              HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />

      <!-- Response -->
      <StackPanel Spacing="6"
                  IsVisible="{Binding ResponseText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
        <TextBlock Classes="field-label" Text="RESPONSE" />
        <TextBox Classes="mono" Text="{Binding ResponseText}" IsReadOnly="True"
                 AcceptsReturn="True" TextWrapping="Wrap" MaxHeight="300" />
      </StackPanel>

    </StackPanel>
  </ScrollViewer>

</UserControl>
