<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AsorAssistant.App.Views.ConfirmDialog"
        Title="Confirm"
        Width="380" Height="160"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Height">

  <Border Padding="24,20">
    <StackPanel Spacing="16">
      <TextBlock x:Name="MessageText" TextWrapping="Wrap" FontSize="13"
                 Foreground="{DynamicResource AppTextPrimaryBrush}" />
      <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
        <Button Classes="action" Content="Cancel" x:Name="CancelButton" />
        <Button Classes="action-primary" Content="Discard" x:Name="DiscardButton" />
      </StackPanel>
    </StackPanel>
  </Border>

</Window>
