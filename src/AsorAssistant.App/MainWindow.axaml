<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AsorAssistant.App.ViewModels"
        xmlns:views="using:AsorAssistant.App.Views"
        xmlns:models="using:AsorAssistant.Core.Models"
        xmlns:domain="using:AsorAssistant.Domain.Models"
        x:Class="AsorAssistant.App.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:Name="MainWin"
        Title="ASOR Assistant"
        Icon="avares://AsorAssistant.App/Assets/app-icon.ico"
        Width="1200" Height="850"
        MinWidth="1050" MinHeight="650">

  <Grid ColumnDefinitions="72,*">

    <!-- Navigation Rail -->
    <Border Grid.Column="0" Background="{DynamicResource AppSurfaceBrush}"
            BorderBrush="{DynamicResource AppBorderSubtleBrush}" BorderThickness="0,0,1,0">
      <DockPanel>
        <StackPanel DockPanel.Dock="Top" Margin="0,16,0,16" HorizontalAlignment="Center">
          <TextBlock Text="ASOR" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"
                     Foreground="{DynamicResource AppAccentBrush}" />
          <TextBlock Text="Assistant" FontSize="8" HorizontalAlignment="Center"
                     Foreground="{DynamicResource AppTextMutedBrush}" Margin="0,1,0,0" />
        </StackPanel>

        <!-- Bottom: theme + help -->
        <StackPanel DockPanel.Dock="Bottom" Spacing="4" Margin="0,0,0,12">
          <Separator Margin="10,0,10,4" Background="{DynamicResource AppBorderSubtleBrush}" />
          <Button HorizontalAlignment="Center"
                  Background="Transparent" CornerRadius="8" Padding="8"
                  Command="{Binding ToggleThemeCommand}"
                  ToolTip.Tip="Toggle light/dark mode">
            <StackPanel Spacing="2" HorizontalAlignment="Center">
              <TextBlock Text="{Binding ThemeIcon}" FontSize="14" HorizontalAlignment="Center" />
              <TextBlock Text="Theme" FontSize="8" HorizontalAlignment="Center"
                         Foreground="{DynamicResource AppTextMutedBrush}" />
            </StackPanel>
          </Button>
          <Button HorizontalAlignment="Center"
                  Background="Transparent" CornerRadius="8" Padding="8"
                  ToolTip.Tip="Help &amp; Documentation">
            <Button.Flyout>
              <Flyout Placement="RightEdgeAlignedTop">
                <StackPanel Spacing="8" Width="280" Margin="4">
                  <TextBlock Text="ASOR Assistant" FontWeight="SemiBold" FontSize="14" />
                  <TextBlock TextWrapping="Wrap" FontSize="12"
                             Foreground="{DynamicResource AppTextSecondaryBrush}"
                             Text="Register external agents against the Workday Agent System of Record (ASOR) API v1.2." />
                  <Button Content="→ ASOR v1.2 Specification" FontSize="12"
                          Foreground="{DynamicResource AppLinkBrush}" Cursor="Hand"
                          Background="Transparent" Padding="0" BorderThickness="0"
                          Click="OnSpecLinkClick" />
                  <Separator Background="{DynamicResource AppBorderSubtleBrush}" />
                  <TextBlock TextWrapping="Wrap" FontSize="11"
                             Foreground="{DynamicResource AppTextMutedBrush}"
                             Text="Regions: US · EU · UK · SIN · IND · JPN&#x0a;Endpoints: {region}.agent.workday.com" />
                </StackPanel>
              </Flyout>
            </Button.Flyout>
            <StackPanel Spacing="2" HorizontalAlignment="Center">
              <TextBlock Text="?" FontSize="14" HorizontalAlignment="Center" FontWeight="Bold"
                         Foreground="{DynamicResource AppTextMutedBrush}" />
              <TextBlock Text="Help" FontSize="8" HorizontalAlignment="Center"
                         Foreground="{DynamicResource AppTextMutedBrush}" />
            </StackPanel>
          </Button>
        </StackPanel>

        <!-- Nav -->
        <ListBox Classes="nav-rail" SelectedIndex="{Binding SelectedPageIndex}">
          <ListBoxItem ToolTip.Tip="Agent Definition Editor">
            <StackPanel Spacing="3" HorizontalAlignment="Center">
              <TextBlock Text="✏" FontSize="18" HorizontalAlignment="Center" />
              <TextBlock Text="Editor" FontSize="9" HorizontalAlignment="Center"
                         Foreground="{DynamicResource AppTextSecondaryBrush}" />
            </StackPanel>
          </ListBoxItem>
          <ListBoxItem ToolTip.Tip="Service Operation Lookups">
            <StackPanel Spacing="3" HorizontalAlignment="Center">
              <TextBlock Text="🔍" FontSize="18" HorizontalAlignment="Center" />
              <TextBlock Text="Lookups" FontSize="9" HorizontalAlignment="Center"
                         Foreground="{DynamicResource AppTextSecondaryBrush}" />
            </StackPanel>
          </ListBoxItem>
        </ListBox>
      </DockPanel>
    </Border>

    <!-- Main Content -->
    <DockPanel Grid.Column="1">

      <!-- Connection Bar — compact card -->
      <Border DockPanel.Dock="Top" Classes="connection-bar">
        <StackPanel Spacing="6">
          <!-- Summary row -->
          <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="Connection" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource AppTextPrimaryBrush}" VerticalAlignment="Center" />
            <Border Classes="badge-success" IsVisible="{Binding HasToken}">
              <TextBlock Text="✓ Connected" FontSize="10" Foreground="{DynamicResource AppSuccessBrush}" FontWeight="Medium" />
            </Border>
            <Border Classes="badge-warning" IsVisible="{Binding !HasToken}">
              <TextBlock Text="⚠ Token required" FontSize="10" Foreground="{DynamicResource AppWarningBrush}" FontWeight="Medium" />
            </Border>
            <TextBlock Text="{Binding SelectedRegion.Name}" FontSize="11"
                       Foreground="{DynamicResource AppTextMutedBrush}" VerticalAlignment="Center"
                       IsVisible="{Binding !IsConnectionBarExpanded}" />
            <Button Classes="action-subtle" Command="{Binding ToggleConnectionBarCommand}"
                    ToolTip.Tip="Show/hide connection details" VerticalAlignment="Center"
                    IsVisible="{Binding !IsConnectionBarExpanded}">
              <TextBlock Text="▾" FontSize="12" />
            </Button>
            <Button Classes="action-subtle" Command="{Binding ToggleConnectionBarCommand}"
                    ToolTip.Tip="Show/hide connection details" VerticalAlignment="Center"
                    IsVisible="{Binding IsConnectionBarExpanded}">
              <TextBlock Text="▴" FontSize="12" />
            </Button>
          </StackPanel>

          <!-- Expanded fields -->
          <StackPanel IsVisible="{Binding IsConnectionBarExpanded}" Spacing="8">
            <StackPanel Orientation="Horizontal" Spacing="16">
              <StackPanel Spacing="3">
                <TextBlock Classes="field-label" Text="REGION" />
                <ComboBox ItemsSource="{Binding Regions}"
                          SelectedItem="{Binding SelectedRegion}"
                          PlaceholderText="Select region..." Width="160">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Name}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
              </StackPanel>
              <StackPanel Spacing="3">
                <TextBlock Classes="field-label" Text="BEARER TOKEN" />
                <TextBox Text="{Binding BearerToken}" PlaceholderText="Paste token from Workday Developer Site"
                         PasswordChar="*" RevealPassword="False" MaxWidth="500" HorizontalAlignment="Left" />
              </StackPanel>
            </StackPanel>
            <TextBlock Classes="helper"
                       Text="Generate at the Workday Developer Site (upper right — login to tenant, copy token). Session-only." />
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Pages -->
      <Panel>
        <!-- Editor Page -->
        <Panel IsVisible="{Binding IsEditorPage}">

          <!-- File Drawer (overlay) -->
          <Border Classes="panel" Width="360" HorizontalAlignment="Left"
                  ZIndex="20" IsVisible="{Binding IsFileDrawerOpen}">
            <ScrollViewer>
              <StackPanel Spacing="0">
                <DockPanel Margin="0,0,0,16">
                  <Button DockPanel.Dock="Right" Classes="action-subtle" Content="✕"
                          Command="{Binding CloseFileDrawerCommand}" />
                  <TextBlock Classes="page-title" Text="Open" />
                </DockPanel>

                <TextBlock Classes="section-header" Text="Local Drafts" />
                <TextBlock Classes="section-desc" Text="Saved on this machine as JSON files." />

                <ItemsControl ItemsSource="{Binding LocalDrafts}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:DraftMetadata">
                      <Border Background="{DynamicResource AppSurfaceRaisedBrush}"
                              CornerRadius="6" Padding="10,8" Margin="0,0,0,4"
                              BorderBrush="{DynamicResource AppBorderSubtleBrush}" BorderThickness="1">
                        <DockPanel>
                          <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                            <Button Classes="action-subtle" Content="✕" ToolTip.Tip="Delete this draft"
                                    Command="{Binding #MainWin.((vm:MainWindowViewModel)DataContext).DeleteDraftCommand}"
                                    CommandParameter="{Binding}" />
                          </StackPanel>
                          <StackPanel Spacing="1">
                            <Button Background="Transparent" Padding="0" BorderThickness="0" Cursor="Hand"
                                    Command="{Binding #MainWin.((vm:MainWindowViewModel)DataContext).LoadDraftCommand}"
                                    CommandParameter="{Binding}">
                              <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="13"
                                         Foreground="{DynamicResource AppTextPrimaryBrush}" />
                            </Button>
                            <TextBlock FontSize="11" Foreground="{DynamicResource AppTextMutedBrush}">
                              <Run Text="{Binding Version}" /><Run Text=" · " /><Run Text="{Binding LastModified, StringFormat='{}{0:g}'}" />
                            </TextBlock>
                          </StackPanel>
                        </DockPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Separator Classes="section-divider" />

                <TextBlock Classes="section-header" Text="From Tenant" />
                <TextBlock Classes="section-desc" Text="Fetch registered agent definitions from Workday." />

                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,10">
                  <ComboBox ItemsSource="{Binding Regions}"
                            SelectedItem="{Binding RemoteRegion}"
                            PlaceholderText="Region" Width="120">
                    <ComboBox.ItemTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding Name}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                  <Button Classes="action-primary" Content="Fetch"
                          Command="{Binding FetchRemoteAgentsCommand}"
                          IsEnabled="{Binding !IsFetchingRemote}" />
                </StackPanel>

                <TextBlock Text="{Binding RemoteStatusMessage}" FontSize="11"
                           Foreground="{DynamicResource AppTextMutedBrush}" Margin="0,0,0,6"
                           IsVisible="{Binding RemoteStatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                <ItemsControl ItemsSource="{Binding RemoteAgents}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="domain:AgentDefinition">
                      <Border Background="{DynamicResource AppSurfaceRaisedBrush}"
                              CornerRadius="6" Padding="10,8" Margin="0,0,0,4"
                              BorderBrush="{DynamicResource AppBorderSubtleBrush}" BorderThickness="1">
                        <Button Background="Transparent" Padding="0" BorderThickness="0" Cursor="Hand"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Command="{Binding #MainWin.((vm:MainWindowViewModel)DataContext).LoadRemoteAgentCommand}"
                                CommandParameter="{Binding}">
                          <StackPanel Spacing="1">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"
                                       Foreground="{DynamicResource AppTextPrimaryBrush}" />
                            <TextBlock FontSize="11" Foreground="{DynamicResource AppTextMutedBrush}">
                              <Run Text="{Binding Version}" /><Run Text=" · " /><Run Text="{Binding Provider.Descriptor}" />
                            </TextBlock>
                          </StackPanel>
                        </Button>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </ScrollViewer>
          </Border>

          <!-- Main 2-pane layout -->
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="340" />
            </Grid.ColumnDefinitions>

          <!-- Editor workspace -->
          <DockPanel Grid.Column="0">
            <!-- Toolbar: three zones -->
            <Border DockPanel.Dock="Top" Classes="page-header" ClipToBounds="True">
              <DockPanel>
                <!-- Right: actions (dock first so they never get clipped) -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center"
                            Margin="8,0,0,0">
                  <Button Classes="action" Content="Validate" Command="{Binding Editor.ValidateCommand}"
                          ToolTip.Tip="Check definition against ASOR v1.2 spec." />
                  <Button Classes="action" Content="Save" Command="{Binding SaveCommand}"
                          ToolTip.Tip="Save to current draft.">
                    <Button.Flyout>
                      <Flyout Placement="BottomEdgeAlignedRight">
                        <StackPanel Spacing="8" Width="280">
                          <TextBlock Text="Save As" FontWeight="SemiBold" />
                          <TextBox Text="{Binding CurrentDraftName}" PlaceholderText="Draft name" />
                          <Button Classes="action-primary" Content="Save" HorizontalAlignment="Stretch"
                                  HorizontalContentAlignment="Center"
                                  Command="{Binding SaveCommand}" />
                        </StackPanel>
                      </Flyout>
                    </Button.Flyout>
                  </Button>
                  <Button Classes="action-primary" Content="Register"
                          Command="{Binding OpenRegistrationPanelCommand}"
                          ToolTip.Tip="POST to Workday ASOR." />
                </StackPanel>

                <!-- Left: file ops + draft name -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center"
                            Margin="0,0,8,0">
                  <Button Classes="action" Content="Open" Command="{Binding ToggleFileDrawerCommand}"
                          ToolTip.Tip="Open a local draft or fetch from tenant." />
                  <Button Classes="action" Content="New" Command="{Binding NewDefinitionCommand}"
                          ToolTip.Tip="Start a blank definition." />
                  <Separator Width="1" Height="18" Background="{DynamicResource AppBorderSubtleBrush}" Margin="4,0" />
                  <TextBlock Text="{Binding CurrentDraftName, FallbackValue='Untitled'}"
                             Foreground="{DynamicResource AppTextMutedBrush}" FontSize="12"
                             VerticalAlignment="Center" MaxWidth="180"
                             TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <!-- Center: mode toggle (last child, fills and centers) -->
                <Border Classes="segment-group" HorizontalAlignment="Center" VerticalAlignment="Center">
                  <StackPanel Orientation="Horizontal" Spacing="2">
                    <Button Classes="segment-active" Content="Visual"
                            Command="{Binding SwitchToVisualCommand}"
                            IsVisible="{Binding IsVisualMode}" />
                    <Button Classes="segment" Content="Visual"
                            Command="{Binding SwitchToVisualCommand}"
                            IsVisible="{Binding IsJsonMode}" />
                    <Button Classes="segment" Content="JSON"
                            Command="{Binding SwitchToJsonCommand}"
                            IsVisible="{Binding IsVisualMode}" />
                    <Button Classes="segment-active" Content="JSON"
                            Command="{Binding SwitchToJsonCommand}"
                            IsVisible="{Binding IsJsonMode}" />
                  </StackPanel>
                </Border>
              </DockPanel>
            </Border>

            <!-- Status bars -->
            <!-- Status message (e.g. "Loaded: External Agent v1") -->
            <Border DockPanel.Dock="Top" Padding="24,6" Background="{DynamicResource AppAccentSubtleBrush}"
                    BorderBrush="{DynamicResource AppBorderSubtleBrush}" BorderThickness="0,0,0,1"
                    IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
              <TextBlock Text="{Binding StatusMessage}" FontSize="11" FontWeight="Medium"
                         Foreground="{DynamicResource AppAccentBrush}" />
            </Border>

            <Border DockPanel.Dock="Top" Padding="24,6" Background="{DynamicResource AppValidationSuccessBgBrush}"
                    BorderBrush="{DynamicResource AppBorderSubtleBrush}" BorderThickness="0,0,0,1"
                    IsVisible="{Binding ShowSaveSuccess}">
              <TextBlock Text="✓ Draft saved" FontSize="11" FontWeight="SemiBold"
                         Foreground="{DynamicResource AppSuccessBrush}" />
            </Border>
            <Border DockPanel.Dock="Top" Padding="24,6" Background="{DynamicResource AppValidationSuccessBgBrush}"
                    BorderBrush="{DynamicResource AppBorderSubtleBrush}" BorderThickness="0,0,0,1"
                    IsVisible="{Binding Editor.IsValid}">
              <TextBlock Text="✓ No validation issues" FontSize="11" FontWeight="SemiBold"
                         Foreground="{DynamicResource AppSuccessBrush}" />
            </Border>
            <Border DockPanel.Dock="Top" Padding="24,8" Background="{DynamicResource AppValidationErrorBgBrush}"
                    BorderBrush="{DynamicResource AppBorderSubtleBrush}" BorderThickness="0,0,0,1"
                    IsVisible="{Binding Editor.ValidationErrors, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
              <DockPanel>
                <Button DockPanel.Dock="Right" Classes="action-subtle" Content="✕"
                        Command="{Binding Editor.DismissErrorsCommand}" ToolTip.Tip="Dismiss" VerticalAlignment="Top" />
                <StackPanel Spacing="2">
                  <TextBlock Text="Validation Errors" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource AppErrorBrush}" />
                  <TextBlock Text="{Binding Editor.ValidationErrors}" FontSize="11" Foreground="{DynamicResource AppErrorBrush}"
                             TextWrapping="Wrap" />
                </StackPanel>
              </DockPanel>
            </Border>

            <!-- Editor content (last child — gets DockPanel fill) -->
            <Panel>
              <views:DefinitionEditorView DataContext="{Binding Editor}"
                                          IsVisible="{Binding #MainWin.((vm:MainWindowViewModel)DataContext).IsVisualMode}" />
              <Border Margin="24,16" Background="{DynamicResource AppSurfaceRaisedBrush}"
                      BorderBrush="{DynamicResource AppBorderSubtleBrush}" BorderThickness="1"
                      CornerRadius="8" Padding="4"
                      IsVisible="{Binding IsJsonMode}">
                <TextBox Classes="mono" Text="{Binding JsonText}"
                         AcceptsReturn="True" TextWrapping="NoWrap" />
              </Border>
            </Panel>
          </DockPanel>

          <!-- Help Panel — quieter, recessed -->
          <Border Grid.Column="1" Padding="20,16"
                  Background="{DynamicResource AppHelpPanelBgBrush}"
                  BorderBrush="{DynamicResource AppBorderSubtleBrush}"
                  BorderThickness="1,0,0,0"
                  IsVisible="{Binding IsVisualMode}">
            <DockPanel>
              <Button DockPanel.Dock="Bottom" Classes="action" Content="← Getting Started"
                      Command="{Binding Editor.ResetHelpCommand}"
                      HorizontalAlignment="Left" Margin="0,12,0,0"
                      IsVisible="{Binding Editor.IsContextualHelp}" />
              <ScrollViewer>
                <StackPanel Spacing="10" DataContext="{Binding Editor}">
                  <TextBlock Text="{Binding HelpTitle}" FontSize="14" FontWeight="SemiBold"
                             Foreground="{DynamicResource AppHelpTitleBrush}" />
                  <TextBlock Text="{Binding HelpContent}" FontSize="12.5"
                             Foreground="{DynamicResource AppHelpBodyBrush}"
                             TextWrapping="Wrap" LineHeight="21" />
                </StackPanel>
              </ScrollViewer>
            </DockPanel>
          </Border>

          </Grid>

          <!-- Registration Panel (overlay) -->
          <Border Classes="panel" Width="400" HorizontalAlignment="Right"
                  ZIndex="20" IsVisible="{Binding IsRegistrationPanelOpen}">
            <views:RegistrationView DataContext="{Binding Registration}" />
          </Border>
        </Panel>

        <!-- Lookups Page -->
        <views:WqlLookupView DataContext="{Binding WqlLookup}"
                             IsVisible="{Binding #MainWin.((vm:MainWindowViewModel)DataContext).IsLookupsPage}" />
      </Panel>
    </DockPanel>
  </Grid>

</Window>
