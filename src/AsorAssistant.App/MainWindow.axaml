<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AsorAssistant.App.ViewModels"
        xmlns:views="using:AsorAssistant.App.Views"
        x:Class="AsorAssistant.App.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="ASOR Assistant"
        Width="1100" Height="850"
        MinWidth="850" MinHeight="650"
        Background="{DynamicResource LayerFillColorAltBrush}">

  <DockPanel>
    <!-- App header -->
    <Border DockPanel.Dock="Top"
            Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
            Padding="24,16">
      <StackPanel Spacing="2">
        <TextBlock Text="ASOR Assistant" FontSize="22" FontWeight="Bold" />
        <TextBlock Text="Agent System of Record — Definition Manager"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="13" />
      </StackPanel>
    </Border>

    <TabControl SelectedIndex="{Binding SelectedTabIndex}"
                Padding="12,8,12,12"
                TabStripPlacement="Top">

      <TabItem Header="  Editor  ">
        <views:DefinitionEditorView DataContext="{Binding Editor}" />
      </TabItem>

      <TabItem Header="  JSON  ">
        <views:JsonPreviewView DataContext="{Binding JsonPreview}" />
      </TabItem>

      <TabItem Header="  Drafts  ">
        <views:DraftManagerView DataContext="{Binding DraftManager}" />
      </TabItem>

      <TabItem Header="  Register  ">
        <views:RegistrationView DataContext="{Binding Registration}" />
      </TabItem>

      <TabItem Header="  WQL Lookup  ">
        <views:WqlLookupView DataContext="{Binding WqlLookup}" />
      </TabItem>

    </TabControl>
  </DockPanel>

</Window>
