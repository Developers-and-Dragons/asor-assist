<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AsorAssistant.App.ViewModels"
        xmlns:views="using:AsorAssistant.App.Views"
        x:Class="AsorAssistant.App.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:Name="MainWin"
        Title="ASOR Assistant"
        Width="1200" Height="850"
        MinWidth="900" MinHeight="650">

  <Grid ColumnDefinitions="68,*">

    <!-- Left Navigation Rail -->
    <Border Grid.Column="0" Background="#0Affffff" BorderBrush="#12ffffff" BorderThickness="0,0,1,0">
      <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="ASOR" FontSize="11" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,16,0,12" Opacity="0.5" />

        <!-- Nav items -->
        <ListBox Classes="nav-rail" SelectedIndex="{Binding SelectedPageIndex}">
          <ListBoxItem ToolTip.Tip="Agent Definition Editor">
            <StackPanel Spacing="4" HorizontalAlignment="Center">
              <TextBlock Text="✏" FontSize="18" HorizontalAlignment="Center" />
              <TextBlock Text="Editor" FontSize="10" HorizontalAlignment="Center" Opacity="0.7" />
            </StackPanel>
          </ListBoxItem>
          <ListBoxItem ToolTip.Tip="JSON Preview">
            <StackPanel Spacing="4" HorizontalAlignment="Center">
              <TextBlock Text="{}{}" FontSize="16" HorizontalAlignment="Center" FontFamily="Cascadia Mono, Consolas, monospace" />
              <TextBlock Text="JSON" FontSize="10" HorizontalAlignment="Center" Opacity="0.7" />
            </StackPanel>
          </ListBoxItem>
          <ListBoxItem ToolTip.Tip="Saved Drafts">
            <StackPanel Spacing="4" HorizontalAlignment="Center">
              <TextBlock Text="📄" FontSize="18" HorizontalAlignment="Center" />
              <TextBlock Text="Drafts" FontSize="10" HorizontalAlignment="Center" Opacity="0.7" />
            </StackPanel>
          </ListBoxItem>
          <ListBoxItem ToolTip.Tip="Service Operation Lookups">
            <StackPanel Spacing="4" HorizontalAlignment="Center">
              <TextBlock Text="🔍" FontSize="18" HorizontalAlignment="Center" />
              <TextBlock Text="Lookups" FontSize="10" HorizontalAlignment="Center" Opacity="0.7" />
            </StackPanel>
          </ListBoxItem>
        </ListBox>

        <!-- Docs link pinned to bottom -->
        <StackPanel DockPanel.Dock="Bottom" VerticalAlignment="Bottom" Margin="0,0,0,16">
          <Separator Margin="8,0" Opacity="0.1" />
          <Button Classes="nav-rail-help" HorizontalAlignment="Center" Margin="0,10,0,0"
                  ToolTip.Tip="Open ASOR v1.2 spec on GitHub">
            <Button.Flyout>
              <Flyout Placement="RightEdgeAlignedTop">
                <StackPanel Spacing="8" Width="260" Margin="4">
                  <TextBlock Text="Help &amp; Docs" FontWeight="SemiBold" FontSize="13" />
                  <TextBlock TextWrapping="Wrap" FontSize="12" Opacity="0.6"
                             Text="This tool registers external agents against the Workday Agent System of Record (ASOR) API v1.2." />
                  <TextBlock Text="ASOR v1.2 Spec" FontSize="12" Foreground="#80a0d0"
                             Cursor="Hand"
                             Tag="https://github.com/Workday/asor/blob/main/versions/v1.2.md" />
                  <TextBlock TextWrapping="Wrap" FontSize="11" Opacity="0.4"
                             Text="Region endpoints: US / EU / UK / SIN / IND / JPN at {region}.agent.workday.com" />
                </StackPanel>
              </Flyout>
            </Button.Flyout>
            <StackPanel Spacing="4" HorizontalAlignment="Center">
              <TextBlock Text="?" FontSize="18" HorizontalAlignment="Center" FontWeight="Bold" />
              <TextBlock Text="Help" FontSize="10" HorizontalAlignment="Center" Opacity="0.7" />
            </StackPanel>
          </Button>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- Content Area -->
    <Panel Grid.Column="1">
      <!-- Page 0: Editor + Registration Panel -->
      <Grid IsVisible="{Binding IsEditorPage}">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <views:DefinitionEditorView DataContext="{Binding Editor}" />

        <Border Grid.Column="1" Classes="panel" Width="400"
                IsVisible="{Binding IsRegistrationPanelOpen}">
          <views:RegistrationView DataContext="{Binding Registration}" />
        </Border>
      </Grid>

      <!-- Page 1: JSON -->
      <views:JsonPreviewView DataContext="{Binding JsonPreview}"
                             IsVisible="{Binding #MainWin.((vm:MainWindowViewModel)DataContext).IsJsonPage}" />

      <!-- Page 2: Drafts -->
      <views:DraftManagerView DataContext="{Binding DraftManager}"
                              IsVisible="{Binding #MainWin.((vm:MainWindowViewModel)DataContext).IsDraftsPage}" />

      <!-- Page 3: Lookups -->
      <views:WqlLookupView DataContext="{Binding WqlLookup}"
                           IsVisible="{Binding #MainWin.((vm:MainWindowViewModel)DataContext).IsLookupsPage}" />
    </Panel>

  </Grid>

</Window>
