<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AsorAssistant.App.App"
             RequestedThemeVariant="Dark">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <!-- ══════════════ Dark ══════════════ -->
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="AppBaseBrush" Color="#212121" />
                    <SolidColorBrush x:Key="AppSurfaceBrush" Color="#2a2a2a" />
                    <SolidColorBrush x:Key="AppSurfaceRaisedBrush" Color="#333333" />
                    <SolidColorBrush x:Key="AppBorderBrush" Color="#4a4a4a" />
                    <SolidColorBrush x:Key="AppBorderSubtleBrush" Color="#484848" />
                    <SolidColorBrush x:Key="AppTextPrimaryBrush" Color="#ececec" />
                    <SolidColorBrush x:Key="AppTextSecondaryBrush" Color="#c0c0c0" />
                    <SolidColorBrush x:Key="AppTextMutedBrush" Color="#999999" />
                    <SolidColorBrush x:Key="AppTextPlaceholderBrush" Color="#666666" />
                    <SolidColorBrush x:Key="AppAccentBrush" Color="#4a90d9" />
                    <SolidColorBrush x:Key="AppAccentSubtleBrush" Color="#1a6baadc" />
                    <SolidColorBrush x:Key="AppSuccessBrush" Color="#5ec26a" />
                    <SolidColorBrush x:Key="AppWarningBrush" Color="#e0a050" />
                    <SolidColorBrush x:Key="AppErrorBrush" Color="#e05555" />
                    <SolidColorBrush x:Key="AppLinkBrush" Color="#7cbce8" />
                    <SolidColorBrush x:Key="AppBadgeSuccessBrush" Color="#185ec26a" />
                    <SolidColorBrush x:Key="AppBadgeWarningBrush" Color="#1ae0a050" />
                    <SolidColorBrush x:Key="AppBadgeErrorBrush" Color="#20e05555" />
                    <SolidColorBrush x:Key="AppValidationSuccessBgBrush" Color="#185ec26a" />
                    <SolidColorBrush x:Key="AppValidationErrorBgBrush" Color="#18e05555" />
                    <SolidColorBrush x:Key="AppSegmentActiveBrush" Color="#444444" />
                    <SolidColorBrush x:Key="AppSegmentInactiveBrush" Color="#2a2a2a" />
                    <SolidColorBrush x:Key="AppHelpPanelBgBrush" Color="#242424" />
                    <SolidColorBrush x:Key="AppHelpTitleBrush" Color="#c0c0c0" />
                    <SolidColorBrush x:Key="AppHelpBodyBrush" Color="#9a9a9a" />
                </ResourceDictionary>

                <!-- ══════════════ Light ══════════════ -->
                <ResourceDictionary x:Key="Light">
                    <!-- Surfaces: tinted base, bright workspace, crisp inputs -->
                    <SolidColorBrush x:Key="AppBaseBrush" Color="#e4e8f0" />
                    <SolidColorBrush x:Key="AppSurfaceBrush" Color="#f8f9fc" />
                    <SolidColorBrush x:Key="AppSurfaceRaisedBrush" Color="#ffffff" />
                    <SolidColorBrush x:Key="AppBorderBrush" Color="#b0b8c8" />
                    <SolidColorBrush x:Key="AppBorderSubtleBrush" Color="#ccd2de" />
                    <!-- Text: rich slate -->
                    <SolidColorBrush x:Key="AppTextPrimaryBrush" Color="#0f172a" />
                    <SolidColorBrush x:Key="AppTextSecondaryBrush" Color="#334155" />
                    <SolidColorBrush x:Key="AppTextMutedBrush" Color="#64748b" />
                    <SolidColorBrush x:Key="AppTextPlaceholderBrush" Color="#708090" />
                    <!-- Accent: bright, confident blue -->
                    <SolidColorBrush x:Key="AppAccentBrush" Color="#2563eb" />
                    <SolidColorBrush x:Key="AppAccentSubtleBrush" Color="#dbeafe" />
                    <!-- Status -->
                    <SolidColorBrush x:Key="AppSuccessBrush" Color="#16a34a" />
                    <SolidColorBrush x:Key="AppWarningBrush" Color="#d97706" />
                    <SolidColorBrush x:Key="AppErrorBrush" Color="#dc2626" />
                    <SolidColorBrush x:Key="AppLinkBrush" Color="#2563eb" />
                    <!-- Badges -->
                    <SolidColorBrush x:Key="AppBadgeSuccessBrush" Color="#d1fae5" />
                    <SolidColorBrush x:Key="AppBadgeWarningBrush" Color="#fef3c7" />
                    <SolidColorBrush x:Key="AppBadgeErrorBrush" Color="#fee2e2" />
                    <SolidColorBrush x:Key="AppValidationSuccessBgBrush" Color="#d1fae5" />
                    <SolidColorBrush x:Key="AppValidationErrorBgBrush" Color="#fee2e2" />
                    <!-- Segment: active gets accent tint -->
                    <SolidColorBrush x:Key="AppSegmentActiveBrush" Color="#ffffff" />
                    <SolidColorBrush x:Key="AppSegmentInactiveBrush" Color="#dce2ee" />
                    <!-- Help panel -->
                    <SolidColorBrush x:Key="AppHelpPanelBgBrush" Color="#eef2ff" />
                    <SolidColorBrush x:Key="AppHelpTitleBrush" Color="#1e3a5f" />
                    <SolidColorBrush x:Key="AppHelpBodyBrush" Color="#3b5278" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml" />

        <!-- Window: include Segoe UI Emoji in font stack for color emoji on Windows -->
        <Style Selector="Window">
          <Setter Property="Background" Value="{DynamicResource AppBaseBrush}" />
          <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}" />
          <Setter Property="FontFamily" Value="Inter, Segoe UI Emoji, sans-serif" />
        </Style>

        <!-- Nav rail -->
        <Style Selector="ListBox.nav-rail">
          <Setter Property="Background" Value="Transparent" />
          <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="ListBox.nav-rail ListBoxItem">
          <Setter Property="Padding" Value="0,12" />
          <Setter Property="HorizontalContentAlignment" Value="Center" />
          <Setter Property="CornerRadius" Value="8" />
          <Setter Property="Margin" Value="4,2" />
        </Style>

        <!-- Page header -->
        <Style Selector="Border.page-header">
          <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
          <Setter Property="BorderBrush" Value="{DynamicResource AppBorderSubtleBrush}" />
          <Setter Property="BorderThickness" Value="0,0,0,1" />
          <Setter Property="Padding" Value="24,10" />
        </Style>

        <!-- Typography -->
        <Style Selector="TextBlock.page-title">
          <Setter Property="FontSize" Value="18" />
          <Setter Property="FontWeight" Value="SemiBold" />
          <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}" />
        </Style>
        <Style Selector="TextBlock.page-subtitle">
          <Setter Property="FontSize" Value="12" />
          <Setter Property="Foreground" Value="{DynamicResource AppTextMutedBrush}" />
          <Setter Property="Margin" Value="0,2,0,0" />
        </Style>
        <Style Selector="TextBlock.section-header">
          <Setter Property="FontSize" Value="14" />
          <Setter Property="FontWeight" Value="SemiBold" />
          <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}" />
          <Setter Property="Margin" Value="0,0,0,2" />
        </Style>
        <Style Selector="TextBlock.section-desc">
          <Setter Property="FontSize" Value="12.5" />
          <Setter Property="Foreground" Value="{DynamicResource AppTextSecondaryBrush}" />
          <Setter Property="Margin" Value="0,0,0,14" />
          <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style Selector="TextBlock.field-label">
          <Setter Property="FontSize" Value="11" />
          <Setter Property="FontWeight" Value="SemiBold" />
          <Setter Property="Foreground" Value="{DynamicResource AppTextSecondaryBrush}" />
          <Setter Property="Margin" Value="0,0,0,4" />
          <Setter Property="LetterSpacing" Value="0.5" />
        </Style>
        <Style Selector="TextBlock.helper">
          <Setter Property="FontSize" Value="12" />
          <Setter Property="Foreground" Value="{DynamicResource AppTextMutedBrush}" />
          <Setter Property="Margin" Value="0,3,0,0" />
          <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style Selector="TextBox.field-invalid">
          <Setter Property="BorderBrush" Value="{DynamicResource AppErrorBrush}" />
        </Style>
        <Style Selector="ComboBox.field-invalid">
          <Setter Property="BorderBrush" Value="{DynamicResource AppErrorBrush}" />
        </Style>
        <Style Selector="TextBlock.card-title">
          <Setter Property="FontSize" Value="13" />
          <Setter Property="FontWeight" Value="SemiBold" />
          <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}" />
        </Style>

        <!-- Inputs -->
        <Style Selector="TextBox">
          <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}" />
          <Setter Property="Background" Value="{DynamicResource AppSurfaceRaisedBrush}" />
          <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
        </Style>
        <Style Selector="TextBox:focus">
          <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
        </Style>
        <Style Selector="TextBox:pointerover">
          <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
        </Style>
        <Style Selector="TextBox /template/ TextBlock#PART_Watermark">
          <Setter Property="Foreground" Value="{DynamicResource AppTextPlaceholderBrush}" />
        </Style>
        <Style Selector="ComboBox">
          <Setter Property="Background" Value="{DynamicResource AppSurfaceRaisedBrush}" />
          <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
          <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}" />
        </Style>
        <Style Selector="ComboBox:focus, ComboBox:pointerover">
          <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
        </Style>
        <Style Selector="ComboBox /template/ Popup Border">
          <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
          <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
        </Style>
        <Style Selector="ComboBoxItem">
          <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}" />
        </Style>
        <Style Selector="ToggleSwitch">
          <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}" />
        </Style>

        <!-- Divider -->
        <Style Selector="Separator.section-divider">
          <Setter Property="Margin" Value="0,24,0,24" />
          <Setter Property="Background" Value="{DynamicResource AppBorderSubtleBrush}" />
        </Style>

        <!-- Surfaces -->
        <Style Selector="Border.surface">
          <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
          <Setter Property="BorderBrush" Value="{DynamicResource AppBorderSubtleBrush}" />
          <Setter Property="BorderThickness" Value="1" />
          <Setter Property="CornerRadius" Value="8" />
          <Setter Property="Padding" Value="16" />
          <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style Selector="Border.surface-inner">
          <Setter Property="Background" Value="{DynamicResource AppSurfaceRaisedBrush}" />
          <Setter Property="BorderBrush" Value="{DynamicResource AppBorderSubtleBrush}" />
          <Setter Property="BorderThickness" Value="1" />
          <Setter Property="CornerRadius" Value="6" />
          <Setter Property="Padding" Value="12" />
          <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
        <Style Selector="Border.panel">
          <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
          <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
          <Setter Property="BorderThickness" Value="1,0,0,0" />
          <Setter Property="Padding" Value="24,20" />
        </Style>
        <Style Selector="Border.connection-bar">
          <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
          <Setter Property="BorderBrush" Value="{DynamicResource AppBorderSubtleBrush}" />
          <Setter Property="BorderThickness" Value="0,0,0,1" />
          <Setter Property="Padding" Value="24,8" />
        </Style>

        <!-- Buttons -->
        <Style Selector="Button.action">
          <Setter Property="Padding" Value="14,6" />
          <Setter Property="CornerRadius" Value="6" />
          <Setter Property="FontSize" Value="12" />
          <Setter Property="FontWeight" Value="Medium" />
        </Style>
        <Style Selector="Button.action-primary">
          <Setter Property="Padding" Value="16,7" />
          <Setter Property="CornerRadius" Value="6" />
          <Setter Property="FontSize" Value="12" />
          <Setter Property="FontWeight" Value="SemiBold" />
          <Setter Property="Background" Value="{DynamicResource AppAccentBrush}" />
          <Setter Property="Foreground" Value="#ffffff" />
        </Style>
        <Style Selector="Button.action-subtle">
          <Setter Property="Padding" Value="8,4" />
          <Setter Property="CornerRadius" Value="4" />
          <Setter Property="FontSize" Value="11" />
          <Setter Property="Foreground" Value="{DynamicResource AppTextMutedBrush}" />
        </Style>
        <Style Selector="Button.action-add">
          <Setter Property="Padding" Value="10,5" />
          <Setter Property="CornerRadius" Value="6" />
          <Setter Property="FontSize" Value="12" />
          <Setter Property="FontWeight" Value="Medium" />
          <Setter Property="Background" Value="{DynamicResource AppAccentSubtleBrush}" />
          <Setter Property="Foreground" Value="{DynamicResource AppAccentBrush}" />
          <Setter Property="BorderThickness" Value="1" />
          <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
        </Style>
        <Style Selector="Button.help-trigger">
          <Setter Property="Padding" Value="0" />
          <Setter Property="Background" Value="Transparent" />
          <Setter Property="BorderThickness" Value="0" />
          <Setter Property="FontSize" Value="14" />
          <Setter Property="Cursor" Value="Hand" />
          <Setter Property="VerticalAlignment" Value="Center" />
          <Setter Property="Opacity" Value="0.7" />
        </Style>
        <Style Selector="Button.help-trigger:pointerover">
          <Setter Property="Opacity" Value="1.0" />
        </Style>

        <!-- Segmented control -->
        <Style Selector="Border.segment-group">
          <Setter Property="Background" Value="{DynamicResource AppSegmentInactiveBrush}" />
          <Setter Property="CornerRadius" Value="6" />
          <Setter Property="Padding" Value="2" />
          <Setter Property="BorderThickness" Value="1" />
          <Setter Property="BorderBrush" Value="{DynamicResource AppBorderSubtleBrush}" />
        </Style>
        <Style Selector="Button.segment">
          <Setter Property="Padding" Value="14,5" />
          <Setter Property="CornerRadius" Value="4" />
          <Setter Property="FontSize" Value="12" />
          <Setter Property="FontWeight" Value="Medium" />
          <Setter Property="Background" Value="Transparent" />
          <Setter Property="BorderThickness" Value="0" />
          <Setter Property="Foreground" Value="{DynamicResource AppTextSecondaryBrush}" />
        </Style>
        <Style Selector="Button.segment-active">
          <Setter Property="Padding" Value="14,5" />
          <Setter Property="CornerRadius" Value="4" />
          <Setter Property="FontSize" Value="12" />
          <Setter Property="FontWeight" Value="SemiBold" />
          <Setter Property="Background" Value="{DynamicResource AppSegmentActiveBrush}" />
          <Setter Property="BorderThickness" Value="0,0,0,2" />
          <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
          <Setter Property="Foreground" Value="{DynamicResource AppAccentBrush}" />
        </Style>

        <Style Selector="TextBox.mono">
          <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, monospace" />
          <Setter Property="FontSize" Value="12" />
        </Style>

        <!-- Badges -->
        <Style Selector="Border.badge-success">
          <Setter Property="CornerRadius" Value="4" />
          <Setter Property="Padding" Value="8,3" />
          <Setter Property="Background" Value="{DynamicResource AppBadgeSuccessBrush}" />
        </Style>
        <Style Selector="Border.badge-warning">
          <Setter Property="CornerRadius" Value="4" />
          <Setter Property="Padding" Value="8,3" />
          <Setter Property="Background" Value="{DynamicResource AppBadgeWarningBrush}" />
        </Style>
        <Style Selector="Border.badge-error">
          <Setter Property="CornerRadius" Value="4" />
          <Setter Property="Padding" Value="8,3" />
          <Setter Property="Background" Value="{DynamicResource AppBadgeErrorBrush}" />
        </Style>
    </Application.Styles>
</Application>
