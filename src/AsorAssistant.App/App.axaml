<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AsorAssistant.App.App"
             RequestedThemeVariant="Dark">

    <Application.Resources>
        <!-- Palette: soft dark slate -->
        <Color x:Key="AppBase">#1b1e24</Color>
        <Color x:Key="AppSurface">#22262e</Color>
        <Color x:Key="AppSurfaceRaised">#2a2f39</Color>
        <Color x:Key="AppSurfaceHigh">#323843</Color>
        <Color x:Key="AppBorder">#3d4350</Color>
        <Color x:Key="AppBorderSubtle">#2f343e</Color>
        <Color x:Key="AppTextPrimary">#e8eaef</Color>
        <Color x:Key="AppTextSecondary">#9ea3b0</Color>
        <Color x:Key="AppTextMuted">#6d7280</Color>
        <Color x:Key="AppAccent">#5b9bd5</Color>
        <Color x:Key="AppSuccess">#5cbd78</Color>
        <Color x:Key="AppWarning">#e0a458</Color>
        <Color x:Key="AppError">#d95555</Color>
        <Color x:Key="AppLink">#7bb8e8</Color>

        <SolidColorBrush x:Key="AppBaseBrush" Color="{StaticResource AppBase}" />
        <SolidColorBrush x:Key="AppSurfaceBrush" Color="{StaticResource AppSurface}" />
        <SolidColorBrush x:Key="AppSurfaceRaisedBrush" Color="{StaticResource AppSurfaceRaised}" />
        <SolidColorBrush x:Key="AppSurfaceHighBrush" Color="{StaticResource AppSurfaceHigh}" />
        <SolidColorBrush x:Key="AppBorderBrush" Color="{StaticResource AppBorder}" />
        <SolidColorBrush x:Key="AppBorderSubtleBrush" Color="{StaticResource AppBorderSubtle}" />
        <SolidColorBrush x:Key="AppTextPrimaryBrush" Color="{StaticResource AppTextPrimary}" />
        <SolidColorBrush x:Key="AppTextSecondaryBrush" Color="{StaticResource AppTextSecondary}" />
        <SolidColorBrush x:Key="AppTextMutedBrush" Color="{StaticResource AppTextMuted}" />
        <SolidColorBrush x:Key="AppAccentBrush" Color="{StaticResource AppAccent}" />
        <SolidColorBrush x:Key="AppSuccessBrush" Color="{StaticResource AppSuccess}" />
        <SolidColorBrush x:Key="AppWarningBrush" Color="{StaticResource AppWarning}" />
        <SolidColorBrush x:Key="AppErrorBrush" Color="{StaticResource AppError}" />
        <SolidColorBrush x:Key="AppLinkBrush" Color="{StaticResource AppLink}" />
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml" />

        <Style Selector="Window">
          <Setter Property="Background" Value="{StaticResource AppBaseBrush}" />
        </Style>

        <!-- Nav rail -->
        <Style Selector="ListBox.nav-rail">
          <Setter Property="Background" Value="Transparent" />
          <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="ListBox.nav-rail ListBoxItem">
          <Setter Property="Padding" Value="0,12" />
          <Setter Property="HorizontalContentAlignment" Value="Center" />
          <Setter Property="CornerRadius" Value="8" />
          <Setter Property="Margin" Value="4,2" />
        </Style>

        <!-- Page header bar (consistent across pages) -->
        <Style Selector="Border.page-header">
          <Setter Property="Background" Value="{StaticResource AppSurfaceBrush}" />
          <Setter Property="BorderBrush" Value="{StaticResource AppBorderSubtleBrush}" />
          <Setter Property="BorderThickness" Value="0,0,0,1" />
          <Setter Property="Padding" Value="28,14" />
        </Style>

        <!-- Typography -->
        <Style Selector="TextBlock.page-title">
          <Setter Property="FontSize" Value="18" />
          <Setter Property="FontWeight" Value="SemiBold" />
          <Setter Property="Foreground" Value="{StaticResource AppTextPrimaryBrush}" />
        </Style>

        <Style Selector="TextBlock.page-subtitle">
          <Setter Property="FontSize" Value="12" />
          <Setter Property="Foreground" Value="{StaticResource AppTextSecondaryBrush}" />
          <Setter Property="Margin" Value="0,2,0,0" />
        </Style>

        <Style Selector="TextBlock.section-header">
          <Setter Property="FontSize" Value="14" />
          <Setter Property="FontWeight" Value="SemiBold" />
          <Setter Property="Foreground" Value="{StaticResource AppTextPrimaryBrush}" />
          <Setter Property="Margin" Value="0,0,0,2" />
        </Style>

        <Style Selector="TextBlock.section-desc">
          <Setter Property="FontSize" Value="12" />
          <Setter Property="Foreground" Value="{StaticResource AppTextSecondaryBrush}" />
          <Setter Property="Margin" Value="0,0,0,14" />
        </Style>

        <Style Selector="TextBlock.field-label">
          <Setter Property="FontSize" Value="11" />
          <Setter Property="FontWeight" Value="SemiBold" />
          <Setter Property="Foreground" Value="{StaticResource AppTextSecondaryBrush}" />
          <Setter Property="Margin" Value="0,0,0,4" />
          <Setter Property="LetterSpacing" Value="0.5" />
        </Style>

        <Style Selector="TextBlock.helper">
          <Setter Property="FontSize" Value="11" />
          <Setter Property="Foreground" Value="{StaticResource AppTextMutedBrush}" />
          <Setter Property="Margin" Value="0,3,0,0" />
        </Style>

        <Style Selector="TextBlock.card-title">
          <Setter Property="FontSize" Value="13" />
          <Setter Property="FontWeight" Value="SemiBold" />
          <Setter Property="Foreground" Value="{StaticResource AppTextPrimaryBrush}" />
        </Style>

        <Style Selector="Separator.section-divider">
          <Setter Property="Margin" Value="0,22,0,22" />
          <Setter Property="Background" Value="{StaticResource AppBorderSubtleBrush}" />
        </Style>

        <!-- Surfaces -->
        <Style Selector="Border.surface">
          <Setter Property="Background" Value="{StaticResource AppSurfaceRaisedBrush}" />
          <Setter Property="BorderBrush" Value="{StaticResource AppBorderSubtleBrush}" />
          <Setter Property="BorderThickness" Value="1" />
          <Setter Property="CornerRadius" Value="8" />
          <Setter Property="Padding" Value="16" />
          <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style Selector="Border.surface-inner">
          <Setter Property="Background" Value="{StaticResource AppSurfaceHighBrush}" />
          <Setter Property="BorderBrush" Value="{StaticResource AppBorderSubtleBrush}" />
          <Setter Property="BorderThickness" Value="1" />
          <Setter Property="CornerRadius" Value="6" />
          <Setter Property="Padding" Value="12" />
          <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <!-- Slide panel -->
        <Style Selector="Border.panel">
          <Setter Property="Background" Value="{StaticResource AppSurfaceBrush}" />
          <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
          <Setter Property="BorderThickness" Value="1,0,0,0" />
          <Setter Property="Padding" Value="24,20" />
        </Style>

        <!-- Connection bar -->
        <Style Selector="Border.connection-bar">
          <Setter Property="Background" Value="{StaticResource AppSurfaceRaisedBrush}" />
          <Setter Property="BorderBrush" Value="{StaticResource AppBorderSubtleBrush}" />
          <Setter Property="BorderThickness" Value="0,0,0,1" />
          <Setter Property="Padding" Value="28,10" />
        </Style>

        <!-- Buttons -->
        <Style Selector="Button.action">
          <Setter Property="Padding" Value="14,7" />
          <Setter Property="CornerRadius" Value="6" />
          <Setter Property="FontSize" Value="12" />
          <Setter Property="FontWeight" Value="Medium" />
        </Style>

        <Style Selector="Button.action-primary">
          <Setter Property="Padding" Value="16,8" />
          <Setter Property="CornerRadius" Value="6" />
          <Setter Property="FontSize" Value="12" />
          <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="Button.action-subtle">
          <Setter Property="Padding" Value="8,4" />
          <Setter Property="CornerRadius" Value="4" />
          <Setter Property="FontSize" Value="11" />
          <Setter Property="Foreground" Value="{StaticResource AppTextMutedBrush}" />
        </Style>

        <Style Selector="Button.action-add">
          <Setter Property="Padding" Value="10,5" />
          <Setter Property="CornerRadius" Value="6" />
          <Setter Property="FontSize" Value="12" />
        </Style>

        <Style Selector="TextBox.mono">
          <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, monospace" />
          <Setter Property="FontSize" Value="12" />
        </Style>

        <!-- Badges -->
        <Style Selector="Border.badge">
          <Setter Property="CornerRadius" Value="4" />
          <Setter Property="Padding" Value="8,3" />
        </Style>
        <Style Selector="Border.badge-success">
          <Setter Property="CornerRadius" Value="4" />
          <Setter Property="Padding" Value="8,3" />
          <Setter Property="Background" Value="#185cbd78" />
        </Style>
        <Style Selector="Border.badge-warning">
          <Setter Property="CornerRadius" Value="4" />
          <Setter Property="Padding" Value="8,3" />
          <Setter Property="Background" Value="#1ae0a458" />
        </Style>
        <Style Selector="Border.badge-error">
          <Setter Property="CornerRadius" Value="4" />
          <Setter Property="Padding" Value="8,3" />
          <Setter Property="Background" Value="#20d95555" />
        </Style>
    </Application.Styles>
</Application>
