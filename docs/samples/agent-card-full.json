{
  "name": "HR Onboarding Agent",
  "description": "Automates new hire onboarding tasks including document collection, system provisioning, and orientation scheduling.",
  "url": "https://agents.example.com/hr-onboarding",
  "version": "2.1.0",
  "provider": {
    "id": "Provider=SELF-BUILT"
  },
  "platform": {
    "id": "Platform=OTHER"
  },
  "capabilities": {
    "pushNotifications": true,
    "streaming": false,
    "stateTransitionHistory": true
  },
